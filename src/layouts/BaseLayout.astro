---
// Utils
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import type { GetImageResult } from "astro";
import "@/styles/root.less";
import "@/styles/dark.less";
import "@/styles/global.css";

// Components
import DynamicHeader from "@/components/Header/DynamicHeader.astro";
import Footer from "@/components/Footer/Footer.astro";
import Meta from "@/components/Meta/Meta.astro";

// Data
import { SITE } from "@/data/client";

// Create a union type for heroImage
type HeroImage = GetImageResult | ImageMetadata;

interface Props {
  title: string;
  description: string;
  heroImage?: HeroImage; // optional - passing a heroImage to BaseLayout will 1. preload the image and 2. use the image for og socials tags in the <head>
}

const { description, title, heroImage } = Astro.props as Props;
---

<html lang={SITE.locale}>
  <head>
    <!-- View Transitions support -->
    <ClientRouter />

    <!-- SEO Meta Tags -->
    <Meta title={title} description={description} heroImage={heroImage}>
      <slot name="schema" slot="schema" />
    </Meta>

    <!-- Astro custom Font API -->
    <Font cssVariable="--font-primary" />

    <!-- If present, preloads the image passed as a prop -->
    {heroImage && <link rel="preload" href={heroImage.src} as="image" />}

    <!-- Sitewide Scripts -->
    <script src="@/js/nav.js"></script>
  </head>
  <body>
    <!-- Screen reader skip main nav -->
    <a class="skip" aria-label="skip to main content" href="#main"
      >Click To Skip To Main Content</a
    >

    <DynamicHeader />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<script is:inline>
  function forceLightMode() {
    document.body.classList.remove("dark-mode");
    localStorage.setItem("theme", "light");
  }

  // Dark mode intentionally disabled for now.
  // To re-enable later, restore original theme detection/toggle logic below.
  /*
  function enableDarkMode() {
    document.body.classList.add("dark-mode");
    localStorage.setItem("theme", "dark");
  }

  function setTheme() {
    let theme = "light";

    if (localStorage.getItem("theme")) {
      theme = localStorage.getItem("theme");
    } else if (
      window.matchMedia &&
      window.matchMedia("(prefers-color-scheme: dark)").matches
    ) {
      theme = "dark";
    }

    theme === "dark" ? enableDarkMode() : forceLightMode();
  }
  */

  forceLightMode();

  // Keep light mode after Astro view transitions.
  document.addEventListener("astro:after-swap", forceLightMode);
</script>

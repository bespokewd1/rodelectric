---
// Utils
import { getImage } from "astro:assets";

// Components
import BaseLayout from "@/layouts/BaseLayout.astro";
import SimpleFAQ from "@/components/FAQ/SimpleFAQ.astro";
import Gallery from "@/components/Gallery/Gallery.astro";
import Hero from "@/components/Hero/Hero.astro";
import OurProcess from "@/components/Process/OurProcess.astro";
import ServiceGrid from "@/components/Services/ServiceGrid.astro";
import TrustSBS from "@/components/SideBySide/trustSBS.astro";
import ServicesClosingCta from "@/components/CTA/ServicesClosingCta.astro";

// Optimize our landing image and pass it as props to the BaseLayout (for preloading) and Banner (for rendering)
import heroImage from "@/assets/images/gallery/installation/installation1.jpg";
import trustImg from "@/assets/images/gallery/installation/installation3.jpg";
import processImg from "@/assets/images/services/residential/basement-electrical5.jpg";

import { getHomeFaqSchema } from "@/data/homeFaq";

const optimizedHeroImage = await getImage({ src: heroImage, format: "webp" });
const homeFaqSchema = getHomeFaqSchema();
---

<BaseLayout
  title="Edmonton Electrician"
  description="Rod's Electrical provides residential and commercial electrical services, repairs, lighting installation, panel upgrades, inspections, and 24/7 emergency support in Edmonton and area."
  heroImage={optimizedHeroImage}
>
  <script
    slot="schema"
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(homeFaqSchema)}
  />
  <Hero image={optimizedHeroImage} />
  <ServiceGrid />
  <TrustSBS trustImg={trustImg} />
  <OurProcess processImg={processImg} />
  <Gallery />
  <SimpleFAQ />
  <ServicesClosingCta />
</BaseLayout>

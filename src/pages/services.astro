---
import { getImage } from "astro:assets";

import ServicesClosingCta from "@/components/CTA/ServicesClosingCta.astro";
import SimpleFAQ from "@/components/FAQ/SimpleFAQ.astro";
import Gallery from "@/components/Gallery/Gallery.astro";
import OurProcess from "@/components/Process/OurProcess.astro";
import ServiceDetailRows from "@/components/Services/ServiceDetailRows.astro";
import ServiceStickyNav from "@/components/Services/ServiceStickyNav.astro";
import ServicesHero from "@/components/Services/ServicesHero.astro";
import TrustSBS from "@/components/SideBySide/trustSBS.astro";
import { getHomeFaqSchema } from "@/data/homeFaq";
import BaseLayout from "@/layouts/BaseLayout.astro";

import heroImage from "@/assets/images/hero/hero.jpg";

const optimizedHeroImage = await getImage({ src: heroImage, format: "webp" });
const homeFaqSchema = getHomeFaqSchema();
---

<BaseLayout
  title="Electrical Services"
  description="Explore residential electrical, commercial work, repairs, lighting installation, panel upgrades, inspections, and emergency support from Rod's Electrical in Edmonton."
  heroImage={optimizedHeroImage}
>
  <script
    slot="schema"
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(homeFaqSchema)}
  />
  <ServicesHero image={optimizedHeroImage} />
  <section
    data-services-nav-zone
    class="bg-white"
    style="--services-sticky-top: 8rem; --services-nav-height: 4.25rem;"
  >
    <ServiceStickyNav />
    <ServiceDetailRows />
  </section>
  <OurProcess variant="form" />
  <SimpleFAQ />
  <ServicesClosingCta />
</BaseLayout>

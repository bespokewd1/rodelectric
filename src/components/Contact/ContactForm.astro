---
import { Icon } from "astro-icon/components";

import OurProcessQuoteForm from "@/components/Process/OurProcessQuoteForm.astro";
import { BUSINESS } from "@/data/client";

const addressLines = [
  BUSINESS.address.lineOne,
  BUSINESS.address.lineTwo,
].filter(Boolean);
const stateZip = [BUSINESS.address.state, BUSINESS.address.zip]
  .filter(Boolean)
  .join(" ");
const cityStateZip = [BUSINESS.address.city, stateZip]
  .filter(Boolean)
  .join(", ");

const contactCards = [
  {
    title: "Phone",
    lines: [BUSINESS.phoneFormatted],
    href: `tel:${BUSINESS.phoneForTel}`,
    icon: "tabler:phone",
    ariaLabel: `Call ${BUSINESS.name} at ${BUSINESS.phoneFormatted}`,
  },
  {
    title: "Location",
    lines: [...addressLines, cityStateZip].filter(Boolean),
    href: BUSINESS.address.mapLink,
    icon: "tabler:map-pin",
    ariaLabel: `View ${BUSINESS.name} address on map`,
    external: true,
  },
  {
    title: "Email us at",
    lines: [BUSINESS.email],
    href: `mailto:${BUSINESS.email}`,
    icon: "tabler:mail",
    ariaLabel: `Email ${BUSINESS.name} at ${BUSINESS.email}`,
  },
];
---

<section
  class="bg-bg-primary py-section relative isolate overflow-hidden px-5 font-sans sm:px-6 lg:px-8"
>
  <div
    class="bg-secondary/12 pointer-events-none absolute top-8 -left-14 h-40 w-40 rounded-full blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div
    class="bg-accent-bright/14 pointer-events-none absolute right-0 bottom-0 h-56 w-56 rounded-full blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto max-w-312">
    <div
      class="flex flex-col gap-8 sm:gap-10 lg:grid lg:grid-cols-[minmax(0,0.92fr)_minmax(22rem,1.08fr)] lg:items-center"
    >
      <div class="lg:max-w-140">
        <ul
          class="m-0 grid list-none grid-cols-1 gap-4 p-0 sm:grid-cols-2 sm:gap-5 lg:grid-cols-1 lg:gap-6"
        >
          {
            contactCards.map((card) => (
              <li class="h-full">
                <a
                  href={card.href}
                  aria-label={card.ariaLabel}
                  target={card.external ? "_blank" : undefined}
                  rel={card.external ? "noreferrer" : undefined}
                  class="group flex h-full min-h-42 items-center rounded-[1.75rem] border border-white/75 bg-[linear-gradient(180deg,rgba(255,255,255,0.98)_0%,rgba(249,252,255,0.92)_100%)] px-6 py-6 shadow-[0_18px_40px_rgba(14,53,94,0.14)] backdrop-blur-sm transition duration-300 hover:-translate-y-1 hover:border-[rgba(255,204,1,0.42)] hover:shadow-[0_24px_56px_rgba(14,53,94,0.18)] focus-visible:-translate-y-1 focus-visible:border-[rgba(255,204,1,0.55)] focus-visible:shadow-[0_24px_56px_rgba(14,53,94,0.18)] focus-visible:outline-none sm:px-7"
                >
                  <span
                    class="text-accent flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-[rgba(255,204,1,0.14)] transition duration-300 group-hover:bg-[rgba(255,204,1,0.2)]"
                    aria-hidden="true"
                  >
                    <Icon name={card.icon} class="size-7" />
                  </span>

                  <div class="ml-5">
                    <h3 class="text-card-heading text-primary m-0">
                      {card.title}:
                    </h3>

                    <div class="mt-3 space-y-1">
                      {card.lines.map((line) => (
                        <p class="text-content-body text-copy-muted m-0 leading-7">
                          {line}
                        </p>
                      ))}
                    </div>
                  </div>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="mx-auto w-full max-w-136 lg:max-w-none">
        <OurProcessQuoteForm />
      </div>
    </div>
  </div>
</section>

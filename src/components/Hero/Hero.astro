---
import type { GetImageResult } from "astro";
import CtaPillButton from "@/components/CTA/CtaPillButton.astro";
import { BUSINESS } from "@/data/client";

interface Props {
  image: GetImageResult;
}

const { image } = Astro.props as Props;

const supportItems = [
  "No obligation quote",
  "Same-day service available",
  "24/7 emergency support",
];
---

<section
  id="hero"
  class="bg-bg-primary overflow-hidden pt-0"
  aria-labelledby="hero-title"
>
  <div class="mx-auto">
    <!-- lg:grid-cols-[minmax(0,0.84fr)_minmax(0,1.16fr)]  -->
    <div
      class="grid gap-8 px-0 pt-10 pb-12 lg:grid-cols-2 lg:items-stretch lg:gap-0 lg:pt-0 lg:pb-0"
    >
      <div
        class="relative flex items-center px-[min(2rem,5vw)] lg:py-14 lg:pr-0 lg:pl-[min(20rem,5vw)] xl:py-18"
      >
        <div
          class="pointer-events-none absolute top-4 left-0 hidden h-36 w-36 rounded-full bg-[rgba(255,204,1,0.24)] blur-3xl lg:block"
          aria-hidden="true"
        >
        </div>
        <div
          class="pointer-events-none absolute right-8 bottom-0 hidden h-48 w-48 rounded-full bg-[rgba(255,255,255,0.75)] blur-3xl lg:block"
          aria-hidden="true"
        >
        </div>

        <div
          class="relative z-10 w-full rounded-4xl border border-white/70 bg-white/55 px-6 py-8 shadow-[0_24px_60px_rgba(111,84,42,0.10)] backdrop-blur-[2px] sm:px-8 sm:py-10 lg:rounded-none lg:border-0 lg:bg-transparent lg:px-0 lg:py-0 lg:shadow-none lg:backdrop-blur-none"
        >
          <h1
            id="hero-title"
            class="text-primary max-w-[12ch] text-[clamp(3.15rem,7vw,5.9rem)] leading-[0.93] font-black tracking-tighter text-balance"
          >
            Electrical work that
            <span class="text-accent">shows up on time</span>
            and gets done to code.
          </h1>

          <p
            class="mt-6 max-w-2xl text-[1rem] leading-8 text-slate-600 sm:text-[1.08rem]"
          >
            Rod&apos;s Electrical provides residential and commercial electrical
            service across Edmonton, from troubleshooting and lighting installs
            to panel upgrades, inspections, and emergency calls.
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <CtaPillButton
              href="/contact/"
              label="Request Free Quote"
              icon="tabler:arrow-right"
              ariaLabel="Request a free quote from Rod's Electrical"
              width="14rem"
            />

            <CtaPillButton
              href={`tel:${BUSINESS.phoneForTel}`}
              label={BUSINESS.phoneFormatted}
              icon="tabler:phone"
              aria-label={`Call ${BUSINESS.name} at ${BUSINESS.phoneFormatted}`}
              width="14rem"
              variant="light"
            />
          </div>

          <!-- <ul class="mt-8 grid list-none gap-3 p-0 sm:grid-cols-3">
            {
              supportItems.map((item) => (
                <li class="rounded-full border border-white/80 bg-white/88 px-4 py-3 text-sm font-medium text-slate-700 shadow-[0_12px_26px_rgba(15,23,42,0.06)] backdrop-blur">
                  <span class="flex items-center gap-3">
                    <span
                      class="bg-accent h-2.5 w-2.5 rounded-full"
                      aria-hidden="true"
                    />
                    <span>{item}</span>
                  </span>
                </li>
              ))
            }
          </ul> -->
        </div>
      </div>

      <div
        class="relative px-[min(2rem,5vw)] lg:min-h-168 lg:px-0 xl:min-h-184"
      >
        <div
          class:list={[
            "relative min-h-72 overflow-hidden rounded-4xl shadow-[0_32px_80px_rgba(111,84,42,0.18)] ring-1 ring-black/5",
            "sm:min-h-96 md:min-h-120 lg:h-full lg:min-h-full lg:rounded-none lg:shadow-none lg:ring-0",
          ]}
        >
          <img
            src={image.src}
            alt="Rod's Electrical providing professional electrician services in Edmonton"
            width={image.attributes.width}
            height={image.attributes.height}
            class="absolute inset-0 h-full w-full object-cover object-[60%_24%] sm:object-[62%_20%] lg:object-[62%_center]"
            loading="eager"
            fetchpriority="high"
          />
          <div
            class="absolute inset-0 bg-[linear-gradient(180deg,rgba(249,243,232,0)_0%,rgba(249,243,232,0.10)_54%,rgba(249,243,232,0.42)_100%)] lg:bg-[linear-gradient(90deg,#f9f3e8_0%,rgba(249,243,232,0.94)_18%,rgba(249,243,232,0.56)_36%,rgba(249,243,232,0)_54%)]"
            aria-hidden="true"
          >
          </div>

          <div
            class="absolute right-4 bottom-4 left-4 sm:right-6 sm:bottom-6 sm:left-6 lg:hidden"
          >
            <div
              class="rounded-3xl border border-white/65 bg-white/90 p-5 shadow-[0_20px_50px_rgba(76,54,28,0.14)] backdrop-blur"
            >
              <p
                class="text-accent text-[0.72rem] font-bold tracking-[0.18em] uppercase"
              >
                Same-Day Support
              </p>
              <p class="mt-3 text-lg leading-7 font-semibold text-slate-900">
                Residential and commercial electrical work across Edmonton,
                backed by fast response and clear communication.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

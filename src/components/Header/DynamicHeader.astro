---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import CtaPillButton from "@/components/CTA/CtaPillButton.astro";

import headerLogo from "@/assets/images/header-icon.png";
import { BUSINESS } from "@/data/client";
import navData from "@/data/navData.json";
import { getDropdownId, isCurrentPage } from "@/js/utils.js";

type NavChild = {
  key: string;
  url: string;
};

type NavEntry = {
  key: string;
  url: string;
  children: NavChild[];
};

const pathname = Astro.url.pathname;
const navigationItems = navData as NavEntry[];

const contactItems = [
  {
    href: `tel:${BUSINESS.phoneForTel}`,
    label: BUSINESS.phoneFormatted,
    icon: "tabler:phone",
  },
  {
    href: `mailto:${BUSINESS.email}`,
    label: BUSINESS.email,
    icon: "tabler:mail",
  },
  {
    href: BUSINESS.address.mapLink,
    label: BUSINESS.address.lineOne,
    icon: "tabler:map-pin",
  },
];

const socialItems = [
  {
    href: BUSINESS.socials.linkedin,
    label: "LinkedIn",
    icon: "tabler:brand-linkedin",
  },
  {
    href: BUSINESS.socials.facebook,
    label: "Facebook",
    icon: "tabler:brand-facebook",
  },
  {
    href: BUSINESS.socials.instagram,
    label: "Instagram",
    icon: "tabler:brand-instagram",
  },
].filter((item) => item.href);

const isEntryActive = (entry: NavEntry) =>
  pathname === entry.url ||
  (entry.url !== "/" && pathname.startsWith(entry.url)) ||
  entry.children.some((child: NavChild) => pathname === child.url);
---

<header
  id="cs-navigation"
  class="sticky inset-x-0 top-0 z-[10000] border-b border-black/5 bg-white/90 shadow-[0_18px_48px_rgba(15,23,42,0.10)] backdrop-blur supports-[backdrop-filter]:bg-white/88 [&.cs-active_.cs-ul-wrapper]:visible [&.cs-active_.cs-ul-wrapper]:translate-y-0 [&.cs-active_.cs-ul-wrapper]:opacity-100"
>
  <div class="bg-[var(--brand-accent)] text-[var(--brand-strong)]">
    <div
      class="mx-auto flex h-12 max-w-[1560px] items-center justify-between px-4 sm:px-6 lg:px-8"
    >
      <div class="hidden items-center gap-4 text-[0.72rem] md:flex lg:gap-7">
        {
          contactItems.map((item) => (
            <a
              href={item.href}
              class="inline-flex items-center gap-2 whitespace-nowrap text-[var(--brand-strong)] transition hover:opacity-75"
            >
              <Icon name={item.icon} class="size-4 shrink-0" />
              <span>{item.label}</span>
            </a>
          ))
        }
      </div>

      {
        socialItems.length > 0 && (
          <div class="ml-auto flex items-center gap-4">
            {socialItems.map((item) => (
              <a
                href={item.href}
                aria-label={item.label}
                class="inline-flex items-center justify-center text-[var(--brand-strong)] transition hover:opacity-75"
              >
                <Icon name={item.icon} class="size-5" />
              </a>
            ))}
          </div>
        )
      }
    </div>
  </div>

  <div class="bg-white">
    <div
      class="relative mx-auto flex min-h-[4.9rem] max-w-390 items-center justify-between gap-3 px-4 sm:px-6 lg:min-h-20 lg:px-8 lg:pl-60"
    >
      <div class="order-1 hidden shrink-0 md:block lg:order-3">
        <CtaPillButton
          href="/contact/"
          label="Contact Us"
          icon="tabler:mail"
          ariaLabel="Contact Us"
          width="9.5rem"
          compactOnMobile={true}
          className="order-1 lg:order-3"
        />
      </div>
      <a
        href="/"
        aria-label="Return to home page"
        class="absolute top-0 left-1/2 z-30 block w-28 -translate-x-1/2 rounded-full bg-white p-4 sm:w-30 md:w-36 lg:left-8 lg:translate-x-0"
      >
        <Image
          src={headerLogo}
          alt="Andiamo Electric logo"
          class="h-auto w-full"
        />
      </a>

      <nav
        aria-label="Main navigation"
        class="contents lg:order-2 lg:block lg:flex-1"
      >
        <div
          id="cs-ul-wrapper"
          class="cs-ul-wrapper invisible absolute inset-x-0 top-full translate-y-4 opacity-0 transition-all duration-300 lg:visible lg:static lg:flex lg:translate-y-0 lg:opacity-100"
        >
          <div class="mx-auto w-full max-w-360 md:px-6 lg:px-0">
            <div
              class="border-t border-slate-200 bg-white px-4 pt-4 pb-5 shadow-[0_24px_40px_rgba(15,23,42,0.12)] md:ml-auto md:rounded-bl-3xl lg:border-0 lg:bg-transparent lg:p-0 lg:shadow-none"
            >
              <ul
                id="cs-expanded"
                class="cs-ul flex flex-col items-start gap-1 lg:flex-row lg:items-center lg:justify-center lg:gap-0"
              >
                {
                  navigationItems.map((entry) => {
                    const entryActive = isEntryActive(entry);

                    return (
                      <li
                        class:list={[
                          "cs-li group relative w-full lg:w-auto",
                          entry.children?.length > 0 &&
                            "cs-dropdown [&.cs-active_.cs-drop-icon]:rotate-180 [&.cs-active_.cs-drop-ul]:mt-3 [&.cs-active_.cs-drop-ul]:max-h-[24rem] [&.cs-active_.cs-drop-ul]:opacity-100",
                        ]}
                      >
                        {entry.children?.length > 0 ? (
                          <>
                            <button
                              id={getDropdownId(entry.key)}
                              type="button"
                              aria-expanded="false"
                              aria-haspopup="menu"
                              class:list={[
                                "cs-dropdown-toggle relative flex w-full items-center justify-start rounded-[0.35rem] px-3 py-3 pr-11 text-left text-[0.98rem] font-medium tracking-[0.01em] text-slate-800 transition duration-200 hover:text-[var(--brand-accent)] focus:ring-2 focus:ring-[var(--brand-accent)]/50 focus:outline-none lg:w-auto lg:gap-2 lg:rounded-none lg:px-4 lg:py-7 lg:pr-4 lg:text-[1rem] before:lg:absolute before:lg:bottom-[1.3rem] before:lg:left-4 before:lg:h-[2px] before:lg:w-0 before:lg:bg-[var(--brand-accent)] before:lg:transition-all",
                                entryActive &&
                                  "text-[var(--brand-strong)] before:lg:w-[calc(100%-2rem)]",
                              ]}
                            >
                              <span>{entry.key}</span>
                              <Icon
                                name="tabler:chevron-down"
                                class="cs-drop-icon absolute top-1/2 right-3 size-4 shrink-0 -translate-y-1/2 transition-transform duration-300 lg:static lg:mt-px lg:translate-y-0"
                              />
                            </button>

                            <ul
                              class="cs-drop-ul flex max-h-0 w-full flex-col items-start overflow-hidden opacity-0 transition-all duration-300 lg:invisible lg:absolute lg:top-full lg:left-0 lg:z-30 lg:mt-6 lg:max-h-none lg:min-w-[15rem] lg:translate-y-3 lg:overflow-visible lg:rounded-sm lg:border lg:border-slate-200 lg:bg-white lg:p-3 lg:opacity-0 lg:shadow-[0_24px_40px_rgba(15,23,42,0.14)] lg:transition-all lg:group-focus-within:visible lg:group-focus-within:mt-4 lg:group-focus-within:translate-y-0 lg:group-focus-within:opacity-100 lg:group-hover:visible lg:group-hover:mt-4 lg:group-hover:translate-y-0 lg:group-hover:opacity-100"
                              aria-labelledby={getDropdownId(entry.key)}
                            >
                              {entry.children.map((child) => (
                                <li class="cs-drop-li w-full">
                                  <a
                                    href={child.url}
                                    class:list={[
                                      "cs-li-link cs-drop-link block w-full rounded-[0.35rem] border-l border-slate-200 px-4 py-2.5 text-left text-sm text-slate-700 transition duration-200 hover:text-[var(--brand-accent)] focus:ring-2 focus:ring-[var(--brand-accent)]/50 focus:outline-none lg:rounded-[0.2rem] lg:border-l-0 lg:px-3",
                                      pathname === child.url &&
                                        "border-[var(--brand-accent)] bg-[var(--brand-accent)] text-[var(--brand-strong)]",
                                    ]}
                                    aria-current={isCurrentPage(
                                      pathname,
                                      child.url,
                                    )}
                                  >
                                    {child.key}
                                  </a>
                                </li>
                              ))}
                            </ul>
                          </>
                        ) : (
                          <a
                            href={entry.url}
                            class:list={[
                              "cs-li-link relative block w-full rounded-[0.35rem] px-3 py-3 text-left text-[0.98rem] font-medium tracking-[0.01em] text-slate-800 transition duration-200 hover:text-[var(--brand-accent)] focus:ring-2 focus:ring-[var(--brand-accent)]/50 focus:outline-none lg:rounded-none lg:px-4 lg:py-7 lg:text-[1rem] before:lg:absolute before:lg:bottom-[1.3rem] before:lg:left-4 before:lg:h-[2px] before:lg:w-0 before:lg:bg-[var(--brand-accent)] before:lg:transition-all",
                              pathname === entry.url &&
                                "text-[var(--brand-strong)] before:lg:w-[calc(100%-2rem)]",
                            ]}
                            aria-current={isCurrentPage(pathname, entry.url)}
                          >
                            {entry.key}
                          </a>
                        )}
                      </li>
                    );
                  })
                }
              </ul>
            </div>
          </div>
        </div>
      </nav>

      <button
        class="cs-toggle relative order-3 inline-flex h-11 w-11 items-center justify-center rounded-[0.2rem] text-[var(--brand-strong)] transition hover:bg-slate-100 focus:ring-2 focus:ring-[var(--brand-accent)]/50 focus:outline-none lg:hidden [&.cs-active_.line-bottom]:-translate-y-[7px] [&.cs-active_.line-bottom]:-rotate-45 [&.cs-active_.line-middle]:opacity-0 [&.cs-active_.line-top]:translate-y-[7px] [&.cs-active_.line-top]:rotate-45"
        id="cs-toggle"
        aria-expanded="false"
        aria-controls="cs-ul-wrapper"
        aria-haspopup="menu"
        aria-label="Open navigation menu"
      >
        <span class="relative block h-4 w-5" aria-hidden="true">
          <span
            class="line-top absolute top-0 left-0 h-[2.5px] w-5 rounded-full bg-current transition-all duration-300"
          ></span>
          <span
            class="line-middle absolute top-[0.42rem] left-0 h-[2.5px] w-5 rounded-full bg-current transition-all duration-300"
          ></span>
          <span
            class="line-bottom absolute bottom-0 left-0 h-[2.5px] w-5 rounded-full bg-current transition-all duration-300"
          ></span>
        </span>
      </button>
    </div>
  </div>
</header>

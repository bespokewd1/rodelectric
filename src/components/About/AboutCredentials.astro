---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

import worksiteImage from "@/assets/images/projects/port8.jpg";

const proofTiles = [
  {
    icon: "tabler:bolt",
    value: "14+ Years",
    label:
      "Hands-on electrical field experience across residential and commercial work.",
  },
  {
    icon: "tabler:shield-check",
    value: "Licensed & Insured",
    label:
      "Company standing backed by proper licensing, insurance, and code-first accountability.",
  },
];

const credentials = [
  {
    icon: "tabler:tool",
    tag: "CERT-01",
    title: "Journeyman Certified Electrician",
    description:
      "Qualified for installation, repair, troubleshooting, and code-compliant electrical work.",
  },
  {
    icon: "tabler:clipboard-check",
    tag: "CERT-02",
    title: "Project Management Certified",
    description:
      "Structured coordination for scopes, sequencing, and delivery from start to finish.",
  },
  {
    icon: "tabler:shield-check",
    tag: "CERT-03",
    title: "CSTS Certified",
    description:
      "Construction safety training that supports disciplined work on active job sites.",
  },
  {
    icon: "tabler:flask",
    tag: "CERT-04",
    title: "WHMIS Certified",
    description:
      "Trained for workplace hazardous materials awareness and safe handling practices.",
  },
  {
    icon: "tabler:ladder",
    tag: "CERT-05",
    title: "Fall Protection Trained",
    description:
      "Prepared for elevated-access conditions when project requirements call for it.",
  },
  {
    icon: "tabler:file-invoice",
    tag: "CERT-06",
    title: "Professional Estimation Expertise",
    description:
      "Clear estimates grounded in practical field knowledge and real project conditions.",
  },
];
---

<section
  id="about-credentials"
  class="bg-bg-primary py-section"
  aria-labelledby="about-credentials-title"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div
      class="overflow-hidden rounded-[2rem] border border-[rgba(0,40,79,0.10)] bg-white shadow-[0_30px_80px_rgba(0,40,79,0.10)]"
    >
      <div class="grid lg:grid-cols-[minmax(19rem,0.82fr)_minmax(0,1.18fr)]">
        <div class="relative min-h-[22rem] lg:min-h-full">
          <Image
            src={worksiteImage}
            alt="Rod's Electrical worksite showing hands-on electrical installation"
            class="absolute inset-0 h-full w-full object-cover"
          />
          <div
            class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,18,36,0.10)_0%,rgba(0,18,36,0.38)_42%,rgba(0,18,36,0.82)_100%)]"
            aria-hidden="true"
          >
          </div>

          <div class="absolute top-4 left-4 sm:top-6 sm:left-6">
            <div
              class="rounded-full border border-white/14 bg-white/12 px-4 py-2 backdrop-blur"
            >
              <p class="text-topper text-white/82">Worksite Ready</p>
            </div>
          </div>

          <div
            class="absolute right-4 bottom-4 left-4 sm:right-6 sm:bottom-6 sm:left-6"
          >
            <div
              class="rounded-[1.5rem] border border-white/12 bg-white/92 px-5 py-5 shadow-[0_18px_42px_rgba(2,8,23,0.22)] backdrop-blur sm:px-6"
            >
              <p class="text-topper text-accent">Verified Standards</p>
              <p
                class="mt-3 text-[1.1rem] leading-8 font-semibold text-slate-900"
              >
                Credentials that back safe work, practical planning, and
                reliable execution on site.
              </p>
            </div>
          </div>
        </div>

        <div class="relative px-6 py-8 sm:px-8 sm:py-10 lg:px-10 lg:py-12">
          <div
            class="bg-accent/18 pointer-events-none absolute top-0 right-0 h-40 w-40 translate-x-1/5 -translate-y-1/5 rounded-full blur-3xl"
            aria-hidden="true"
          >
          </div>

          <div class="relative z-10">
            <p class="text-topper text-accent">Credentials</p>
            <h2
              id="about-credentials-title"
              class="text-primary mt-4 text-[clamp(2.6rem,5vw,4.2rem)] leading-[0.96] font-black tracking-[-0.05em]"
            >
              Certified, licensed, and field-tested for safe electrical work.
            </h2>

            <p class="text-section-body mt-6 max-w-3xl text-slate-700">
              Clients are hiring trained professionals with real field hours,
              verified safety credentials, and practical project knowledge for
              code-compliant work that holds up after install day.
            </p>

            <div class="mt-8 grid gap-4 md:grid-cols-2">
              {
                proofTiles.map((item) => (
                  <article class="rounded-[1.4rem] border border-[rgba(0,40,79,0.08)] bg-[linear-gradient(135deg,rgba(255,255,255,1)_0%,rgba(249,243,232,0.88)_100%)] px-5 py-5 shadow-[0_18px_38px_rgba(0,40,79,0.06)]">
                    <div class="flex items-start gap-4">
                      <span
                        class="bg-accent/20 text-primary flex h-11 w-11 shrink-0 items-center justify-center rounded-full"
                        aria-hidden="true"
                      >
                        <Icon name={item.icon} class="size-5" />
                      </span>
                      <div>
                        <p class="text-primary text-[1.1rem] leading-6 font-bold">
                          {item.value}
                        </p>
                        <p class="text-content-body mt-2 text-slate-600">
                          {item.label}
                        </p>
                      </div>
                    </div>
                  </article>
                ))
              }
            </div>

            <div class="mt-6 grid gap-4 md:grid-cols-2">
              {
                credentials.map((item) => (
                  <article class="rounded-[1.4rem] border border-[rgba(0,40,79,0.08)] bg-[linear-gradient(135deg,rgba(255,255,255,1)_0%,rgba(249,243,232,0.88)_100%)] px-5 py-5 shadow-[0_18px_38px_rgba(0,40,79,0.06)]">
                    <div class="flex items-start gap-4">
                      <span
                        class="bg-accent/20 text-primary flex h-11 w-11 shrink-0 items-center justify-center rounded-full"
                        aria-hidden="true"
                      >
                        <Icon name={item.icon} class="size-5" />
                      </span>
                      <div>
                        <h3 class="text-card-heading text-primary mt-2">
                          {item.title}
                        </h3>
                        <p class="text-content-body mt-3 text-slate-600">
                          {item.description}
                        </p>
                      </div>
                    </div>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

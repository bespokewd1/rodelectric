---
import { Icon } from "astro-icon/components";
import type { GetImageResult } from "astro";
import CtaPillButton from "@/components/CTA/CtaPillButton.astro";
import { BUSINESS } from "@/data/client";

interface Props {
  image: GetImageResult;
}

const { image } = Astro.props as Props;

const sharedProofItems = [
  "Edmonton owned and operated",
  "14+ years of hands-on experience",
  "Licensed, insured, and certified",
  "Residential and commercial support",
];
---

<section
  id="about-hero"
  class="bg-bg-primary py-section"
  aria-labelledby="about-hero-title"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div
      class="border-primary/10 overflow-hidden rounded-[2rem] border bg-[linear-gradient(135deg,rgba(255,255,255,0.98)_0%,rgba(249,243,232,0.98)_100%)] shadow-[0_30px_80px_rgba(0,40,79,0.10)]"
    >
      <div
        class="grid gap-8 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:items-stretch"
      >
        <div class="relative px-6 py-8 sm:px-8 sm:py-10 lg:px-10 lg:py-12">
          <div
            class="bg-accent/20 absolute top-0 right-0 h-36 w-36 rounded-full blur-3xl"
            aria-hidden="true"
          >
          </div>

          <p class="text-topper text-accent relative z-10">
            About Rod&apos;s Electrical
          </p>
          <h1
            id="about-hero-title"
            class="text-primary text-hero-title relative z-10 mt-4 max-w-[10.5ch]"
          >
            Trusted Edmonton electrical work, done right first time.
          </h1>
          <p
            class="text-section-body relative z-10 mt-5 max-w-2xl text-slate-700"
          >
            Rod&apos;s Electrical is locally owned and operated, with over 14
            years of hands-on field experience serving homeowners and businesses
            through safe, code-compliant electrical work that lasts.
          </p>

          <div
            class="relative z-10 mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap"
          >
            <CtaPillButton
              href="/contact/"
              label="Request A Quote"
              icon="tabler:arrow-right"
              ariaLabel="Request a quote from Rod's Electrical"
              width="14rem"
            />
            <CtaPillButton
              href={`tel:${BUSINESS.phoneForTel}`}
              label={BUSINESS.phoneFormatted}
              icon="tabler:phone"
              ariaLabel={`Call ${BUSINESS.name} at ${BUSINESS.phoneFormatted}`}
              width="14rem"
              variant="light"
            />
          </div>

          <ul
            class="relative z-10 mt-8 grid list-none gap-3 p-0 sm:grid-cols-2"
          >
            {
              sharedProofItems.map((item) => (
                <li class="rounded-[1.25rem] border border-white/70 bg-white/88 px-4 py-4 shadow-[0_14px_30px_rgba(0,40,79,0.06)] backdrop-blur">
                  <div class="flex items-center gap-3">
                    <span
                      class="bg-accent/20 text-primary flex h-9 w-9 shrink-0 items-center justify-center rounded-full"
                      aria-hidden="true"
                    >
                      <Icon name="tabler:bolt" class="size-4" />
                    </span>
                    <span class="text-content-body font-semibold text-slate-700">
                      {item}
                    </span>
                  </div>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="relative min-h-[24rem] overflow-hidden lg:min-h-full">
          <img
            src={image.src}
            alt="Interior electrical work and lighting installation by Rod's Electrical in Edmonton"
            width={image.attributes.width}
            height={image.attributes.height}
            class="absolute inset-0 h-full w-full object-cover object-center"
            loading="eager"
            fetchpriority="high"
          />
          <div
            class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,40,79,0.08)_0%,rgba(0,40,79,0.18)_48%,rgba(0,40,79,0.78)_100%)] lg:bg-[linear-gradient(90deg,rgba(249,243,232,0.08)_0%,rgba(249,243,232,0)_20%,rgba(0,40,79,0.58)_100%)]"
            aria-hidden="true"
          >
          </div>
          <div
            class="absolute right-4 bottom-4 left-4 sm:right-6 sm:bottom-6 sm:left-6"
          >
            <div
              class="rounded-[1.5rem] border border-white/15 bg-white/92 p-5 shadow-[0_20px_50px_rgba(2,8,23,0.18)] backdrop-blur"
            >
              <p class="text-topper text-accent">Local Trust</p>
              <p class="mt-3 text-lg leading-7 font-semibold text-slate-900">
                Licensed and insured electrical support for Edmonton homes and
                businesses.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

import constructionImage from "@/assets/images/services/construction.jpg";
import worksiteImage from "@/assets/images/projects/port8.jpg";

interface Props {
  variant?: "editorial" | "worksite" | "foundry";
}

const { variant = "editorial" } = Astro.props as Props;

const storyParagraphs = [
  "Great electrical work is not just wires and panels. It is safety, trust, and quality that still holds up long after the tools are packed away.",
  "Rod's Electrical is locally owned and operated in Edmonton, proudly serving homeowners and businesses with practical workmanship and clear communication.",
  "From day one, the standard has been simple: do the job right the first time, follow code carefully, and treat every property with real respect.",
];

const storyCallouts = [
  {
    title: "Locally owned",
    description:
      "Clients work with Edmonton-rooted people who value long-term trust over rushed turnover.",
    icon: "tabler:map-pin",
  },
  {
    title: "Code-first work",
    description:
      "Safety and compliance stay at the center of every repair, upgrade, and installation.",
    icon: "tabler:shield-check",
  },
  {
    title: "Respectful workmanship",
    description:
      "Homes, businesses, and jobsites are handled with care from setup to final cleanup.",
    icon: "tabler:home",
  },
];

const storyMarkers = [
  "Safety before shortcuts",
  "Lasting quality over quick fixes",
  "Careful work for homes and businesses",
];
---

<!-- Variant options: editorial | worksite | foundry -->{
  variant === "editorial" && (
    <section
      id="about-story"
      class="py-section relative overflow-hidden bg-white"
      aria-labelledby="about-story-title"
    >
      <div
        class="bg-accent/16 pointer-events-none absolute top-10 left-0 h-44 w-44 -translate-x-1/3 rounded-full blur-3xl"
        aria-hidden="true"
      ></div>
      <div
        class="bg-primary/10 pointer-events-none absolute right-0 bottom-0 h-52 w-52 translate-x-1/4 rounded-full blur-3xl"
        aria-hidden="true"
      ></div>

      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-6 lg:grid-cols-[minmax(0,1.06fr)_minmax(20rem,0.94fr)]">
          <div class="overflow-hidden rounded-[2rem] border border-[rgba(0,40,79,0.10)] bg-[linear-gradient(135deg,rgba(255,255,255,0.98)_0%,rgba(249,243,232,0.96)_100%)] px-6 py-8 shadow-[0_28px_70px_rgba(0,40,79,0.08)] sm:px-8 sm:py-10 lg:px-10 lg:py-12">
            <p class="text-topper text-accent">Our Story</p>
            <h2
              id="about-story-title"
              class="text-primary mt-4 max-w-[11ch] text-[clamp(2.8rem,5vw,4.7rem)] leading-[0.95] font-black tracking-[-0.05em]"
            >
              Built on safety, trust, and work that lasts.
            </h2>

            <div class="mt-6 max-w-3xl space-y-4">
              {storyParagraphs.map((paragraph) => (
                <p class="text-section-body text-slate-700">{paragraph}</p>
              ))}
            </div>

            <div class="mt-8 rounded-[1.5rem] bg-[var(--brand-strong)] px-5 py-5 shadow-[0_24px_50px_rgba(0,40,79,0.22)] sm:px-6">
              <p class="text-topper text-white/72">Day One Standard</p>
              <p class="mt-3 max-w-[34ch] text-[1.05rem] leading-8 font-semibold text-white">
                Do job right first time, follow code, and leave every property
                better cared for than we found it.
              </p>
            </div>
          </div>

          <aside class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
            {storyCallouts.map((item) => (
              <article class="rounded-[1.5rem] border border-[rgba(0,40,79,0.08)] bg-white px-5 py-5 shadow-[0_16px_38px_rgba(15,23,42,0.06)] sm:px-6">
                <div class="flex items-start gap-4">
                  <span
                    class="bg-accent/20 text-primary flex h-11 w-11 shrink-0 items-center justify-center rounded-full"
                    aria-hidden="true"
                  >
                    <Icon name={item.icon} class="size-5" />
                  </span>
                  <div>
                    <h3 class="text-card-heading text-primary">{item.title}</h3>
                    <p class="text-content-body mt-2 text-slate-600">
                      {item.description}
                    </p>
                  </div>
                </div>
              </article>
            ))}

            <article class="rounded-[1.75rem] border border-[rgba(255,204,1,0.34)] bg-[linear-gradient(135deg,rgba(255,248,232,1)_0%,rgba(255,255,255,1)_100%)] px-6 py-6 shadow-[0_18px_45px_rgba(0,40,79,0.08)] sm:col-span-2 lg:col-span-1">
              <p class="text-topper text-primary">Who We Serve</p>
              <p class="mt-3 text-[1.1rem] leading-8 font-semibold text-slate-900">
                Homeowners and businesses across Edmonton who need reliable
                electrical work without shortcuts.
              </p>
            </article>
          </aside>
        </div>
      </div>
    </section>
  )
}

{
  variant === "worksite" && (
    <section
      id="about-story"
      class="bg-bg-primary py-section"
      aria-labelledby="about-story-title"
    >
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="overflow-hidden rounded-[2rem] border border-[rgba(0,40,79,0.10)] bg-white shadow-[0_30px_80px_rgba(0,40,79,0.10)]">
          <div class="grid lg:grid-cols-[minmax(19rem,0.86fr)_minmax(0,1.14fr)]">
            <div class="relative min-h-[22rem] lg:min-h-full">
              <Image
                src={constructionImage}
                alt="Rod's Electrical jobsite workmanship"
                class="absolute inset-0 h-full w-full object-cover"
              />
              <div
                class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,18,36,0.08)_0%,rgba(0,18,36,0.72)_100%)]"
                aria-hidden="true"
              ></div>
              <div class="absolute right-4 bottom-4 left-4 sm:right-6 sm:bottom-6 sm:left-6">
                <div class="rounded-[1.5rem] border border-white/12 bg-white/92 px-5 py-5 shadow-[0_18px_42px_rgba(2,8,23,0.22)] backdrop-blur">
                  <p class="text-topper text-accent">Edmonton Rooted</p>
                  <p class="mt-3 text-[1.1rem] leading-8 font-semibold text-slate-900">
                    Local company, practical standards, and workmanship built to
                    hold up after finish day.
                  </p>
                </div>
              </div>
            </div>

            <div class="relative px-6 py-8 sm:px-8 sm:py-10 lg:px-10 lg:py-12">
              <div
                class="bg-accent/18 pointer-events-none absolute top-0 right-0 h-40 w-40 translate-x-1/5 -translate-y-1/5 rounded-full blur-3xl"
                aria-hidden="true"
              ></div>

              <div class="relative z-10">
                <p class="text-topper text-accent">Our Story</p>
                <h2
                  id="about-story-title"
                  class="text-primary mt-4 max-w-[11ch] text-[clamp(2.6rem,5vw,4.2rem)] leading-[0.96] font-black tracking-[-0.05em]"
                >
                  Work done with care, not corners cut.
                </h2>

                <div class="mt-6 max-w-3xl space-y-4">
                  {storyParagraphs.map((paragraph) => (
                    <p class="text-section-body text-slate-700">{paragraph}</p>
                  ))}
                </div>

                <div class="mt-8 grid gap-3 sm:grid-cols-3">
                  {storyMarkers.map((marker, index) => (
                    <article class="rounded-[1.35rem] border border-[rgba(0,40,79,0.08)] bg-[rgba(249,243,232,0.66)] px-4 py-4">
                      <p class="text-accent text-[0.78rem] font-bold tracking-[0.2em] uppercase">
                        0{index + 1}
                      </p>
                      <h3 class="text-card-heading text-primary mt-3">
                        {marker}
                      </h3>
                    </article>
                  ))}
                </div>

                <div class="mt-8 rounded-[1.5rem] border border-[rgba(0,40,79,0.08)] bg-[linear-gradient(135deg,rgba(255,255,255,1)_0%,rgba(249,243,232,0.8)_100%)] px-5 py-5 sm:px-6">
                  <p class="text-topper text-primary">What Matters Most</p>
                  <p class="mt-3 text-[1.05rem] leading-8 font-semibold text-slate-900">
                    Safe results, honest standards, and properties treated with
                    same respect we would expect in our own space.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}

{
  variant === "foundry" && (
    <section
      id="about-story"
      class="py-section bg-[linear-gradient(180deg,rgba(0,40,79,1)_0%,rgba(0,28,56,1)_100%)]"
      aria-labelledby="about-story-title"
    >
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-6 lg:grid-cols-[minmax(0,0.84fr)_minmax(0,1.16fr)] lg:items-stretch">
          <div class="rounded-[2rem] border border-white/12 bg-white/6 px-6 py-8 shadow-[0_30px_70px_rgba(2,8,23,0.28)] backdrop-blur sm:px-8 sm:py-10">
            <p class="text-topper text-accent">Our Story</p>
            <h2
              id="about-story-title"
              class="mt-4 max-w-[10ch] text-[clamp(2.7rem,4.5vw,4.4rem)] leading-[0.95] font-black tracking-[-0.05em] text-white"
            >
              Local standards. Careful work. No shortcuts.
            </h2>
            <p class="mt-5 max-w-[34ch] text-[1.05rem] leading-8 text-white/78">
              Rod&apos;s Electrical was built around one simple idea: electrical
              work should feel safe, dependable, and worth trusting.
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
              {storyMarkers.map((marker) => (
                <span class="rounded-full border border-white/14 bg-white/8 px-4 py-2 text-[0.82rem] font-semibold tracking-[0.06em] text-white/86 uppercase">
                  {marker}
                </span>
              ))}
            </div>

            <div class="relative mt-8 overflow-hidden rounded-[1.5rem]">
              <Image
                src={worksiteImage}
                alt="Electrical project detail by Rod's Electrical"
                class="h-full min-h-[16rem] w-full object-cover"
              />
              <div
                class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,18,36,0.04)_20%,rgba(0,18,36,0.8)_100%)]"
                aria-hidden="true"
              ></div>
              <p class="absolute right-4 bottom-4 left-4 text-lg leading-7 font-semibold text-white sm:right-5 sm:bottom-5 sm:left-5">
                Built for homes and businesses that need safe work to last.
              </p>
            </div>
          </div>

          <div class="rounded-[2rem] bg-[linear-gradient(135deg,rgba(255,255,255,1)_0%,rgba(248,250,252,1)_100%)] px-6 py-8 shadow-[0_28px_70px_rgba(2,8,23,0.18)] sm:px-8 sm:py-10 lg:px-10 lg:py-12">
            <div class="h-1.5 w-16 rounded-full bg-[var(--brand-accent)]" />

            <div class="mt-6 space-y-4">
              {storyParagraphs.map((paragraph) => (
                <p class="text-section-body text-slate-700">{paragraph}</p>
              ))}
            </div>

            <div class="mt-8 grid gap-4 sm:grid-cols-3">
              {storyCallouts.map((item) => (
                <article class="rounded-[1.35rem] border border-[rgba(0,40,79,0.08)] bg-white px-4 py-5 shadow-[0_14px_34px_rgba(15,23,42,0.05)]">
                  <span
                    class="bg-accent/18 text-primary flex h-10 w-10 items-center justify-center rounded-full"
                    aria-hidden="true"
                  >
                    <Icon name={item.icon} class="size-4.5" />
                  </span>
                  <h3 class="text-card-heading text-primary mt-4">
                    {item.title}
                  </h3>
                  <p class="text-content-body mt-2 text-slate-600">
                    {item.description}
                  </p>
                </article>
              ))}
            </div>

            <div class="mt-8 rounded-[1.5rem] border border-[rgba(255,204,1,0.32)] bg-[linear-gradient(135deg,rgba(255,248,232,1)_0%,rgba(255,255,255,1)_100%)] px-5 py-5 sm:px-6">
              <p class="text-topper text-primary">Daily Standard</p>
              <p class="mt-3 text-[1.05rem] leading-8 font-semibold text-slate-900">
                Job done right first time, code followed closely, and every
                property treated like it matters.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}

---
import { Image } from "astro:assets";

import CtaPillButton from "@/components/CTA/CtaPillButton.astro";
import { BUSINESS } from "@/data/client";

import ctaImage from "@/assets/images/projects/port7.jpg";
---

<section
  id="services-closing-cta"
  class="bg-white px-5 py-12 font-sans sm:px-6 sm:py-14 lg:px-8 lg:py-18"
  aria-labelledby="services-closing-cta-title"
>
  <div class="mx-auto max-w-312">
    <div
      class="overflow-hidden rounded-[2rem] border border-[rgba(255,204,1,0.28)] bg-[linear-gradient(135deg,#fff8e8_0%,#f6f8fb_54%,#eef4fb_100%)] shadow-[0_28px_70px_rgba(15,23,42,0.10)]"
    >
      <div class="grid lg:grid-cols-[minmax(0,1.02fr)_minmax(18rem,0.98fr)]">
        <div class="relative px-6 py-8 sm:px-8 sm:py-10 lg:px-10 lg:py-12">
          <div
            class="bg-accent/28 pointer-events-none absolute top-0 left-0 h-40 w-40 -translate-x-1/3 -translate-y-1/3 rounded-full blur-3xl"
            aria-hidden="true"
          >
          </div>
          <div class="relative z-10 max-w-2xl">
            <p class="text-topper text-accent m-0 uppercase">
              Need Service Fast?
            </p>
            <h2
              id="services-closing-cta-title"
              class="text-section-title text-primary m-0 mt-3 uppercase"
            >
              Book dependable electrical help without the runaround.
            </h2>
            <p
              class="mt-5 text-[1rem] leading-8 text-slate-600 sm:text-[1.08rem]"
            >
              From small repairs to panel upgrades and urgent troubleshooting,
              Rod&apos;s Electrical shows up ready to work safely, clearly, and
              on time.
            </p>

            <div
              class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:flex-wrap"
            >
              <CtaPillButton
                href="/contact/"
                label="Request Free Quote"
                icon="tabler:arrow-right"
                ariaLabel="Request a free quote from Rod's Electrical"
                width="14rem"
              />
              <CtaPillButton
                href={`tel:${BUSINESS.phoneForTel}`}
                label={BUSINESS.phoneFormatted}
                icon="tabler:phone"
                ariaLabel={`Call ${BUSINESS.name} at ${BUSINESS.phoneFormatted}`}
                width="14rem"
              />
            </div>
          </div>
        </div>

        <div class="relative min-h-[18rem] sm:min-h-[22rem] lg:min-h-full">
          <Image
            src={ctaImage}
            alt="Rod's Electrical project work"
            class="absolute inset-0 h-full w-full object-cover"
          />
          <div
            class="absolute inset-0 bg-[linear-gradient(180deg,rgba(8,27,52,0.06)_0%,rgba(8,27,52,0.76)_100%)]"
            aria-hidden="true"
          >
          </div>
          <div
            class="absolute right-5 bottom-5 left-5 sm:right-6 sm:bottom-6 sm:left-6"
          >
            <p class="text-topper m-0 text-white/80 uppercase">24/7 Support</p>
            <p class="mt-3 text-xl leading-8 font-semibold text-white">
              Emergency calls available when power problems cannot wait until
              morning.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

---
import CtaPillButton from "@/components/CTA/CtaPillButton.astro";
import { BUSINESS } from "@/data/client";
---

<div class="h-28 md:hidden" aria-hidden="true"></div>

<div
  id="mobile-sticky-cta"
  class="pointer-events-none fixed inset-x-0 bottom-0 z-[9990] px-4 pb-[calc(env(safe-area-inset-bottom)+0.75rem)] transform-gpu translate-y-0 transition-transform duration-300 ease-out will-change-transform md:hidden"
>
  <div class="mx-auto max-w-[34rem]">
    <div
      class="pointer-events-auto rounded-[1.75rem] border border-white/70 bg-white/96 p-3 shadow-[0_24px_48px_rgba(15,23,42,0.16)] backdrop-blur supports-[backdrop-filter]:bg-white/88"
    >
      <div class="grid grid-cols-[minmax(0,0.96fr)_minmax(0,1.14fr)] gap-3">
        <CtaPillButton
          href="/contact/"
          label="Contact Us"
          icon="tabler:mail"
          ariaLabel="Contact Us"
          width="100%"
        />
        <CtaPillButton
          href={`tel:${BUSINESS.phoneForTel}`}
          label={BUSINESS.phoneFormatted}
          icon="tabler:phone"
          ariaLabel={`Call ${BUSINESS.name} at ${BUSINESS.phoneFormatted}`}
          width="100%"
        />
      </div>
    </div>
  </div>
</div>

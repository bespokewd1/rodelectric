---
// Gallery component from index.astro

// Utils
import { Picture } from "astro:assets";
import CtaPillButton from "@/components/CTA/CtaPillButton.astro";

// Images
import basement1 from "@/assets/images/services/residential/basement-electrical.jpg";
import basement2 from "@/assets/images/services/residential/basement-electrical2.jpg";
import basement3 from "@/assets/images/services/residential/basement-electrical3.jpg";
import basement4 from "@/assets/images/services/residential/basement-electrical4.jpg";
import basement5 from "@/assets/images/services/residential/basement-electrical5.jpg";
import basement6 from "@/assets/images/services/residential/basement-electrical6.jpg";
import basement7 from "@/assets/images/services/residential/basement-electrical7.jpg";
import basement8 from "@/assets/images/services/residential/basement-electrical8.jpg";

import installation from "@/assets/images/gallery/installation/installation4.jpg";
// Image list — column-major order (col1, col2, col3)
const images = [
  { src: basement1, alt: "basement electrical rough-in" },
  { src: basement2, alt: "basement wiring installation" },
  { src: basement3, alt: "basement panel work" },
  { src: basement4, alt: "basement electrical conduit" },
  { src: basement5, alt: "basement junction box install" },
  { src: basement6, alt: "basement lighting wiring" },
  { src: basement7, alt: "basement outlet rough-in" },
  { src: basement8, alt: "basement electrical finish" },
  { src: installation, alt: "installation" },
];

const PER_ROW = 3;
const rows = Array.from(
  { length: Math.ceil(images.length / PER_ROW) },
  (_, i) => images.slice(i * PER_ROW, i * PER_ROW + PER_ROW),
);
---

<section id="gallery">
  <div class="cs-container">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-topper text-accent m-0 uppercase">Our Portfolio</p>
      <h2 class="text-section-title m-0 mt-3 text-balance uppercase">
        Recent Electrical Projects
      </h2>
      <p class="text-section-body text-copy-muted m-0 mx-auto mt-5 max-w-3xl">
        Browse recent residential and commercial electrical work completed by
        Rod&apos;s Electrical across Edmonton and surrounding areas.
      </p>
    </div>
    <div class="cs-image-group overflow-x-clip">
      {
        rows.map((row, rowIdx) => (
          <div class={`cs-row cs-row-${(rowIdx % 3) + 1}`}>
            {row.map((img, picIdx) => (
              <Picture
                src={img.src}
                alt={img.alt}
                width={400}
                height={560}
                formats={["avif", "webp"]}
                pictureAttributes={{
                  class: `cs-picture cs-picture${picIdx + 1}`,
                }}
              />
            ))}
          </div>
        ))
      }
    </div>
    <div class="flex justify-center">
      <CtaPillButton
        href="/projects/"
        label="View All Projects"
        icon="tabler:arrow-right"
        width="13rem"
      />
    </div>
  </div>
</section>

<style lang="less">
  /*-- -------------------------- -->
<---          Gallery           -->
<--- -------------------------- -*/

  /* Mobile - 360px - Contains hover animation */
  @media only screen and (min-width: 0em) {
    #gallery {
      /* Centers button */
      text-align: center;
      padding: var(--sectionPadding);
      position: relative;
      /* Prevents overflow from the image going off screen */
      overflow: hidden;
      .cs-container {
        width: 100%;
        max-width: (1322/16em);
        margin: auto;
      }

      .cs-topper {
        text-align: center;
        margin-bottom: (16/16rem);
      }

      .cs-title {
        text-align: center;
        max-width: (621/16rem);
        margin-bottom: (40/16rem);
      }

      .cs-image-group {
        /* used rem so it doesn't scale with the font size of on parent */
        font-size: ~"min(1.1vw, 1em)";
        width: 100%;
        max-width: (1322/16em);
        margin: clamp(2.5rem, 5vw, 3.75rem) auto (60/16rem);
        padding: 0;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        gap: (30/16em);
        /* Scroll cap — mobile (stacked) */
        max-height: 80vh;
        overflow-y: auto;
        scrollbar-width: thin;
      }

      .cs-row {
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        align-items: center;
        gap: (30/16em);
      }

      .cs-picture {
        display: block;
        position: relative;
        img {
          width: 100%;
          height: 100%;
          object-fit: cover;
          position: absolute;
          top: 0;
          left: 0;
        }
      }

      .cs-row-1 {
        .cs-picture1 {
          width: (420/16em);
          height: (567/16em);
        }

        .cs-picture2 {
          width: (420/16em);
          height: (629/16em);
        }

        .cs-picture3 {
          width: (420/16em);
          height: (512/16em);
        }
      }

      .cs-row-2 {
        .cs-picture1 {
          width: (420/16em);
          height: (492/16em);
        }

        .cs-picture2 {
          width: (420/16em);
          height: (517/16em);
        }

        .cs-picture3 {
          width: (420/16em);
          height: (629/16em);
        }
      }

      .cs-row-3 {
        .cs-picture1 {
          width: (420/16em);
          height: (625/16em);
        }

        .cs-picture2 {
          width: (420/16em);
          height: (452/16em);
        }

        .cs-picture3 {
          width: (420/16em);
          height: (629/16em);
        }
      }
    }
  }

  /* Desktop scroll cap */
  @media only screen and (min-width: 64em) {
    #gallery {
      .cs-image-group {
        max-height: (1400/16rem);
      }
    }
  }

  /* Dark mode */
  @media only screen and (min-width: 0em) {
    body.dark-mode {
      #gallery {
        .cs-title {
          color: var(--bodyTextColorWhite);
        }
      }
    }
  }
</style>

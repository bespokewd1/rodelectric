---
import { Image } from "astro:assets";
import CtaPillButton from "@/components/CTA/CtaPillButton.astro";
import OurProcessQuoteForm from "@/components/Process/OurProcessQuoteForm.astro";
import { BUSINESS } from "@/data/client";
// import processImg from "@/assets/images/projects/port6.jpg";

interface Props {
  variant?: "image" | "form";
  processImg: ImageMetadata;
}

const { variant = "image", processImg } = Astro.props as Props;
const isFormVariant = variant === "form";

const processSteps = [
  {
    title: "Contact Us",
    description:
      "Call us at (587) 399-3722 or fill out our online form. Describe your electrical needs and schedule a convenient time.",
    descriptionClass: "max-w-[30ch]",
  },
  {
    title: "Free Assessment & Quote",
    description:
      "We assess your electrical situation, discuss your needs, and provide a clear, honest quote with no hidden fees.",
    descriptionClass: "max-w-[31ch]",
  },
  {
    title: "Safe & Professional Work",
    description:
      "Our licensed electrician completes the work safely, efficiently, and to code. You get peace of mind and quality results.",
    descriptionClass: "max-w-[30ch]",
  },
];
---

<section
  class="bg-bg-primary py-section relative isolate overflow-hidden px-5 font-sans sm:px-6 lg:px-8"
>
  <div
    class="bg-secondary/12 pointer-events-none absolute top-8 -left-14 h-40 w-40 rounded-full blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div
    class="bg-accent-bright/14 pointer-events-none absolute right-0 bottom-0 h-56 w-56 rounded-full blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto max-w-312">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-topper text-accent m-0 uppercase">How It Works</p>
      <h2 class="text-section-title m-0 mt-3 text-balance uppercase">
        Our Simple Process
      </h2>
      <p
        class="text-section-body text-copy-muted m-0 mx-auto mt-5 max-w-[46rem]"
      >
        Getting professional electrical service is simple. Here’s our
        straightforward 3-step process:
      </p>
    </div>
    <!-- lg:grid-cols-[minmax(0,1fr)_minmax(24rem,1fr)] -->
    <div
      class:list={[
        "mt-10 flex flex-col gap-8 sm:mt-12 sm:gap-10 lg:grid",
        isFormVariant
          ? "lg:grid-cols-[minmax(0,0.92fr)_minmax(22rem,1.08fr)] lg:items-center"
          : "lg:grid-cols-[auto_minmax(24rem,1fr)] lg:items-center",
      ]}
    >
      <div class="lg:max-w-140">
        <ol
          class="m-0 grid list-none grid-cols-1 gap-4 p-0 sm:grid-cols-2 sm:gap-5 lg:grid-cols-1 lg:gap-6"
        >
          {
            processSteps.map((step, index) => (
              <li class="h-full">
                <article class="flex min-h-62 flex-col rounded-3xl border border-white/70 bg-[linear-gradient(180deg,rgba(255,255,255,0.96)_0%,rgba(249,252,255,0.92)_100%)] p-6 shadow-sm backdrop-blur-sm sm:min-h-66 sm:p-7 lg:min-h-70">
                  <p class="text-process text-accent/50 m-0">
                    {String(index + 1).padStart(2, "0")}
                  </p>
                  <h3 class="text-card-heading text-primary m-0 mt-4 text-balance">
                    {step.title}
                  </h3>
                  <p
                    class:list={[
                      "text-content-body text-copy m-0 mt-4",
                      // step.descriptionClass,
                    ]}
                  >
                    {step.description}
                  </p>
                </article>
              </li>
            ))
          }
        </ol>

        {
          !isFormVariant && (
            <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:flex-wrap">
              <CtaPillButton
                href="/contact/"
                label="Get Free Quote"
                icon="tabler:file-invoice"
                ariaLabel="Get a free quote from Rod's Electrical"
                width="14rem"
              />
              <CtaPillButton
                href={`tel:${BUSINESS.phoneForTel}`}
                label={BUSINESS.phoneFormatted}
                icon="tabler:phone"
                ariaLabel={`Call ${BUSINESS.name} at ${BUSINESS.phoneFormatted}`}
                width="14rem"
                variant="light"
              />
            </div>
          )
        }
      </div>

      <div class="mx-auto w-full max-w-136 lg:max-w-none">
        {
          isFormVariant ? (
            <OurProcessQuoteForm />
          ) : (
            <div class="relative">
              <Image
                src={processImg}
                alt="our process img"
                class={
                  "relative block max-h-250 overflow-hidden rounded-[1.75rem] border border-white/75 bg-white shadow-[0_24px_56px_rgba(14,53,94,0.2)]"
                }
              />
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>

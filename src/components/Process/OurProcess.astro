          </div>
          <div
            class="gm:pointer-events-none gm:absolute gm:-bottom-6 gm:-left-6 gm:h-36 gm:w-36 gm:rounded-full gm:bg-accent-bright/16 gm:blur-3xl"
            aria-hidden="true"
          >
          </div>
          <picture
            class="gm:relative gm:block gm:overflow-hidden gm:rounded-[1.75rem] gm:border gm:border-white/75 gm:bg-white gm:shadow-[0_24px_56px_rgba(14,53,94,0.2)]"
          >
            <img
              class="gm:block gm:h-auto gm:max-w-full gm:w-full gm:object-cover gm:lg:h-[39rem]"
              src="https://glassma.us/wp-content/uploads/2026/04/residential-window-glass-replacement.webp"
              alt="Glassma technician replacing residential window glass at a Seattle home"
              width="960"
              height="1280"
              loading="lazy"
              decoding="async"
            />
          </picture>
        </div>
      </div>

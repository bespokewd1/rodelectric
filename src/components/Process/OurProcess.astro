>
  <div
    class="gm:pointer-events-none gm:absolute gm:-left-14 gm:top-8 gm:h-40 gm:w-40 gm:rounded-full gm:bg-secondary/12 gm:blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div
    class="gm:pointer-events-none gm:absolute gm:bottom-0 gm:right-0 gm:h-56 gm:w-56 gm:rounded-full gm:bg-accent-bright/14 gm:blur-3xl"
    aria-hidden="true"

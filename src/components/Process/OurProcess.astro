---
const processSteps = [
  {
    title: "Inspection & Quote",
    description:
      "We visit your home to inspect the damage, measure the glass, and provide a clear, written estimate.",
    descriptionClass: "max-w-[30ch]",
  },
  {
    title: "Glass Fabrication",
    description:
      "We order or fabricate glass to your exact specs-single-pane, tempered safety glass, or energy-efficient double-pane (IGU) units with the right Low-E and thickness.",
    descriptionClass: "max-w-[31ch]",
  },
  {
    title: "Professional Installation",
    description:
      "We carefully remove the old glass, clean the frame, install the new unit, and seal it against the weather.",
    descriptionClass: "max-w-[30ch]",
  },
  {
    title: "Final Walkthrough",
    description:
      "We ensure the window opens and closes correctly and that the glass is spotless before we leave.",
    descriptionClass: "max-w-[30ch]",
  },
];
---

<section
  class="bg-primary/10 relative isolate overflow-hidden px-5 py-12 font-sans sm:px-6 sm:py-14 lg:px-8 lg:py-20"
>
  <div
    class="bg-secondary/12 pointer-events-none absolute top-8 -left-14 h-40 w-40 rounded-full blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div
    class="bg-accent-bright/14 pointer-events-none absolute right-0 bottom-0 h-56 w-56 rounded-full blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto max-w-312">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-section-title m-0">OUR SIMPLE PROCESS</h2>
      <p
        class="text-section-body text-copy-muted m-0 mx-auto mt-5 max-w-[46rem]"
      >
        From the first phone call to the final polish, we make glass replacement
        easy.
      </p>
    </div>

    <div
      class="mt-10 flex flex-col gap-8 sm:mt-12 sm:gap-10 lg:grid lg:grid-cols-[minmax(0,1.05fr)_minmax(24rem,0.95fr)] lg:items-start"
    >
      <ol
        class="m-0 grid list-none grid-cols-1 gap-4 p-0 sm:grid-cols-2 sm:gap-5 lg:gap-6"
      >
        {
          processSteps.map((step, index) => (
            <li class="h-full">
              <article class="shadow-card flex min-h-[15.5rem] flex-col rounded-[1.5rem] border border-white/70 bg-[linear-gradient(180deg,rgba(255,255,255,0.96)_0%,rgba(249,252,255,0.92)_100%)] p-6 backdrop-blur-sm sm:min-h-[16.5rem] sm:p-7 lg:min-h-[17.5rem]">
                <p class="text-process text-accent/50 m-0">
                  {String(index + 1).padStart(2, "0")}
                </p>
                <h3 class="text-card-heading text-primary m-0 mt-4 text-balance">
                  {step.title}
                </h3>
                <p
                  class:list={[
                    "text-content-body text-copy m-0 mt-4",
                    step.descriptionClass,
                  ]}
                >
                  {step.description}
                </p>
              </article>
            </li>
          ))
        }
      </ol>

      <div class="mx-auto w-full max-w-136 lg:max-w-none">
        <div class="relative">
          <div
            class="bg-secondary/18 pointer-events-none absolute -top-5 -right-5 h-28 w-28 rounded-full blur-3xl sm:-top-6 sm:-right-6 sm:h-32 sm:w-32"
            aria-hidden="true"
          >
          </div>
          <div
            class="bg-accent-bright/16 pointer-events-none absolute -bottom-6 -left-6 h-36 w-36 rounded-full blur-3xl"
            aria-hidden="true"
          >
          </div>
          <picture
            class="relative block overflow-hidden rounded-[1.75rem] border border-white/75 bg-white shadow-[0_24px_56px_rgba(14,53,94,0.2)]"
          >
            <img
              class="block h-auto w-full max-w-full object-cover lg:h-[39rem]"
              src="https://glassma.us/wp-content/uploads/2026/04/residential-window-glass-replacement.webp"
              alt="Glassma technician replacing residential window glass at a Seattle home"
              width="960"
              height="1280"
              loading="lazy"
              decoding="async"
            />
          </picture>
        </div>
      </div>
    </div>
  </div>
</section>

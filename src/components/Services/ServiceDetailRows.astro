---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

import CtaPillButton from "@/components/CTA/CtaPillButton.astro";
import { serviceHubItems } from "@/data/services";
---

<section
  id="service-details"
  class="bg-white px-5 py-12 font-sans sm:px-6 sm:py-14 lg:px-8 lg:py-18"
  aria-labelledby="service-details-title"
>
  <div class="mx-auto max-w-312">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-topper text-accent m-0 uppercase">Service Details</p>
      <h2
        id="service-details-title"
        class="text-section-title text-primary m-0 mt-3 uppercase"
      >
        Electrical Support Matched To The Work
      </h2>
      <p class="mt-5 text-[1rem] leading-8 text-slate-600 sm:text-[1.08rem]">
        Jump into the service you need now, then contact us for clear pricing,
        scheduling, and dependable electrical work across Edmonton.
      </p>
    </div>

    <div class="mt-10 grid gap-6 sm:mt-12 lg:gap-8">
      {
        serviceHubItems.map((service, index) => {
          const images =
            service.detailImages && service.detailImages.length > 0
              ? service.detailImages
              : [service.detailImage];
          const hasMultiple = images.length > 1;

          const imageBlock = (
            <div
              class:list={[
                "relative min-h-[18rem] overflow-hidden bg-slate-100 sm:min-h-[24rem] lg:min-h-full",
                hasMultiple &&
                  "touch-pan-y select-none cursor-grab data-[dragging=true]:cursor-grabbing",
              ]}
              data-service-carousel={hasMultiple ? "true" : undefined}
              role={hasMultiple ? "group" : undefined}
              aria-roledescription={hasMultiple ? "carousel" : undefined}
              aria-label={hasMultiple ? `${service.title} images` : undefined}
            >
              {images.map((img, i) => (
                <div
                  class="absolute inset-0"
                  data-carousel-slide
                  data-active={i === 0 ? "true" : "false"}
                  style={`opacity: ${i === 0 ? 1 : 0}; pointer-events: ${i === 0 ? "auto" : "none"};`}
                  role={hasMultiple ? "group" : undefined}
                  aria-roledescription={hasMultiple ? "slide" : undefined}
                  aria-label={
                    hasMultiple ? `${i + 1} of ${images.length}` : undefined
                  }
                  aria-hidden={hasMultiple && i !== 0 ? "true" : undefined}
                >
                  <Image
                    src={img}
                    alt={service.alt}
                    class="absolute inset-0 h-full w-full object-cover"
                  />
                  <div
                    class="absolute inset-0 bg-[linear-gradient(180deg,rgba(8,27,52,0.04)_0%,rgba(8,27,52,0.12)_100%)]"
                    aria-hidden="true"
                  />
                </div>
              ))}

              {hasMultiple && (
                <>
                  <button
                    type="button"
                    data-carousel-prev
                    aria-label="Previous image"
                    class="absolute top-1/2 left-3 z-10 inline-flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-white/70 text-slate-800 shadow-[0_4px_14px_rgba(15,23,42,0.18)] backdrop-blur-sm transition hover:bg-white hover:text-[var(--brand-strong)] focus:ring-2 focus:ring-[var(--brand-accent)]/60 focus:outline-none sm:left-4"
                  >
                    <Icon name="tabler:chevron-left" class="size-5" />
                  </button>
                  <button
                    type="button"
                    data-carousel-next
                    aria-label="Next image"
                    class="absolute top-1/2 right-3 z-10 inline-flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-white/70 text-slate-800 shadow-[0_4px_14px_rgba(15,23,42,0.18)] backdrop-blur-sm transition hover:bg-white hover:text-[var(--brand-strong)] focus:ring-2 focus:ring-[var(--brand-accent)]/60 focus:outline-none sm:right-4"
                  >
                    <Icon name="tabler:chevron-right" class="size-5" />
                  </button>

                  <div
                    class="absolute bottom-3 left-1/2 z-10 flex -translate-x-1/2 items-center gap-1.5 rounded-full bg-white/55 px-2.5 py-1.5 backdrop-blur-sm sm:bottom-4"
                    role="tablist"
                    aria-label="Select image"
                  >
                    {images.map((_, i) => (
                      <button
                        type="button"
                        data-carousel-dot
                        data-index={i}
                        data-active={i === 0 ? "true" : "false"}
                        role="tab"
                        aria-label={`Show image ${i + 1}`}
                        aria-selected={i === 0 ? "true" : "false"}
                        class="h-1.5 w-1.5 rounded-full bg-slate-800/40 transition-all duration-300 hover:bg-slate-800/70 focus:ring-2 focus:ring-[var(--brand-accent)]/60 focus:outline-none data-[active=true]:w-5 data-[active=true]:bg-[var(--brand-accent)]"
                      />
                    ))}
                  </div>
                </>
              )}
            </div>
          );

          const contentBlock = (
            <div class="flex flex-col justify-center px-6 py-7 sm:px-8 sm:py-9 lg:px-10">
              <p class="text-topper text-accent m-0 uppercase">
                {service.title}
              </p>
              <h3 class="text-primary mt-4 text-[clamp(1.85rem,2.6vw,2.85rem)] leading-[1.08] font-bold text-balance">
                {service.detailHeading}
              </h3>
              <p class="mt-4 text-[1rem] leading-8 text-slate-600">
                {service.detailBody}
              </p>

              <ul class="m-0 mt-6 grid list-none gap-3 p-0">
                {service.bullets.map((bullet) => (
                  <li class="flex items-start gap-3 text-[0.98rem] leading-7 text-slate-700">
                    <span
                      class="bg-accent mt-[0.72rem] h-2.5 w-2.5 shrink-0 rounded-full"
                      aria-hidden="true"
                    />
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>

              <div class="mt-8 flex flex-wrap gap-4">
                <CtaPillButton
                  href="/contact/"
                  label="Request Service"
                  icon="tabler:arrow-right"
                  ariaLabel={`Request ${service.title} from Rod's Electrical`}
                  width="13rem"
                />
              </div>
            </div>
          );

          return (
            <article
              id={service.id}
              data-service-section
              class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_22px_48px_rgba(15,23,42,0.08)]"
              style="scroll-margin-top: calc(var(--services-sticky-top) + var(--services-nav-height) + 1rem);"
            >
              <div class="grid lg:grid-cols-2 lg:items-stretch">
                {index % 2 === 0 ? (
                  <>
                    {contentBlock}
                    {imageBlock}
                  </>
                ) : (
                  <>
                    {imageBlock}
                    {contentBlock}
                  </>
                )}
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  [data-carousel-slide] {
    transition:
      opacity 500ms ease-out,
      transform 220ms ease-out;
  }
  [data-service-carousel][data-dragging="true"] [data-carousel-slide] {
    transition: opacity 500ms ease-out;
  }
  [data-service-carousel] img {
    -webkit-user-drag: none;
    user-select: none;
  }
</style>

<script>
  const carousels = document.querySelectorAll<HTMLElement>(
    "[data-service-carousel]",
  );

  carousels.forEach((carousel) => {
    const slides = Array.from(
      carousel.querySelectorAll<HTMLElement>("[data-carousel-slide]"),
    );
    const dots = Array.from(
      carousel.querySelectorAll<HTMLElement>("[data-carousel-dot]"),
    );
    const prevBtn = carousel.querySelector<HTMLButtonElement>(
      "[data-carousel-prev]",
    );
    const nextBtn = carousel.querySelector<HTMLButtonElement>(
      "[data-carousel-next]",
    );

    if (slides.length <= 1) return;

    let current = 0;

    const setActive = (index: number) => {
      const next = (index + slides.length) % slides.length;
      slides.forEach((slide, i) => {
        const isActive = i === next;
        slide.dataset.active = isActive ? "true" : "false";
        slide.style.opacity = isActive ? "1" : "0";
        slide.style.pointerEvents = isActive ? "auto" : "none";
        if (isActive) {
          slide.removeAttribute("aria-hidden");
        } else {
          slide.setAttribute("aria-hidden", "true");
        }
      });
      dots.forEach((dot, i) => {
        const isActive = i === next;
        dot.dataset.active = isActive ? "true" : "false";
        dot.setAttribute("aria-selected", isActive ? "true" : "false");
      });
      current = next;
    };

    prevBtn?.addEventListener("click", () => setActive(current - 1));
    nextBtn?.addEventListener("click", () => setActive(current + 1));

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => setActive(i));
    });

    carousel.addEventListener("keydown", (event) => {
      if (event.key === "ArrowLeft") {
        event.preventDefault();
        setActive(current - 1);
      } else if (event.key === "ArrowRight") {
        event.preventDefault();
        setActive(current + 1);
      }
    });

    // Pointer-based swipe gesture (covers both touch and mouse).
    // Buttons (prev / next / dots) are excluded via closest() so their
    // click handlers above are never shadowed by drag logic.
    const INTERACTIVE_SELECTOR =
      "[data-carousel-prev],[data-carousel-next],[data-carousel-dot]";
    const LOCK_THRESHOLD = 8; // px before we decide horizontal vs vertical
    const COMMIT_THRESHOLD = 50; // px to commit a slide change
    const RESISTANCE = 0.4; // visual translate factor while dragging

    let pointerId: number | null = null;
    let startX = 0;
    let startY = 0;
    let deltaX = 0;
    let dragging = false;
    let horizontalLock = false;

    const isInteractive = (target: EventTarget | null) => {
      if (!(target instanceof Element)) return false;
      return !!target.closest(INTERACTIVE_SELECTOR);
    };

    const resetActiveTransform = (snapBack: boolean) => {
      const slide = slides[current];
      if (!slide) return;
      // Restore the stylesheet transition so the snap back is smooth.
      slide.style.transition = "";
      slide.style.transform = snapBack ? "" : "";
    };

    const onPointerDown = (event: PointerEvent) => {
      if (isInteractive(event.target)) return;
      // Only react to the primary mouse button; touch / pen always pass.
      if (event.pointerType === "mouse" && event.button !== 0) return;

      pointerId = event.pointerId;
      startX = event.clientX;
      startY = event.clientY;
      deltaX = 0;
      dragging = true;
      horizontalLock = false;
    };

    const onPointerMove = (event: PointerEvent) => {
      if (!dragging || event.pointerId !== pointerId) return;
      const dx = event.clientX - startX;
      const dy = event.clientY - startY;

      if (!horizontalLock) {
        if (Math.abs(dx) < LOCK_THRESHOLD && Math.abs(dy) < LOCK_THRESHOLD) {
          return;
        }
        if (Math.abs(dy) > Math.abs(dx)) {
          // Vertical movement wins -> abort so the page can scroll.
          dragging = false;
          horizontalLock = false;
          pointerId = null;
          return;
        }
        horizontalLock = true;
        carousel.dataset.dragging = "true";
        try {
          carousel.setPointerCapture(event.pointerId);
        } catch {
          // Older browsers may throw; we just keep tracking events normally.
        }
      }

      event.preventDefault();
      deltaX = dx;
      const active = slides[current];
      if (active) {
        active.style.transition = "none";
        active.style.transform = `translateX(${deltaX * RESISTANCE}px)`;
      }
    };

    const finishDrag = (event: PointerEvent) => {
      if (!dragging || event.pointerId !== pointerId) return;
      const wasHorizontal = horizontalLock;
      const committedDelta = deltaX;

      dragging = false;
      horizontalLock = false;
      pointerId = null;
      delete carousel.dataset.dragging;

      try {
        if (carousel.hasPointerCapture(event.pointerId)) {
          carousel.releasePointerCapture(event.pointerId);
        }
      } catch {
        // ignore
      }

      if (!wasHorizontal) return;

      // Reset transform on the currently visible slide so it animates
      // back to 0 (whether we commit a slide change or not).
      resetActiveTransform(true);

      if (committedDelta > COMMIT_THRESHOLD) {
        setActive(current - 1);
      } else if (committedDelta < -COMMIT_THRESHOLD) {
        setActive(current + 1);
      }
    };

    carousel.addEventListener("pointerdown", onPointerDown);
    carousel.addEventListener("pointermove", onPointerMove);
    carousel.addEventListener("pointerup", finishDrag);
    carousel.addEventListener("pointercancel", finishDrag);
    // Block native HTML5 image drag-and-drop so it doesn't hijack our gesture.
    carousel.addEventListener("dragstart", (event) => event.preventDefault());
  });
</script>

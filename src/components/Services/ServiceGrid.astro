---
import { Picture } from "astro:assets";
import { Icon } from "astro-icon/components";
import CtaPillButton from "@/components/CTA/CtaPillButton.astro";
import { serviceHubItems } from "@/data/services";
import { BUSINESS } from "@/data/client";

interface Props {
  ctaPrefix?: string;
  sectionId?: string;
}

const { ctaPrefix = "/services/#", sectionId = "services-grid" } =
  Astro.props as Props;

const accentTitleId = "panel-upgrades-inspections";

const serviceCards = serviceHubItems.map((service) => ({
  ...service,
  href: `${ctaPrefix}${service.id}`,
  isAccent: service.id === accentTitleId,
}));
---

<section
  id={sectionId}
  class="py-section relative isolate overflow-hidden bg-white px-5 sm:px-6 lg:px-8"
  aria-labelledby="services-grid-title"
>
  <div
    class="bg-accent/14 pointer-events-none absolute top-16 left-0 h-48 w-48 -translate-x-1/3 rounded-full blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div
    class="bg-primary/10 pointer-events-none absolute right-0 bottom-10 h-60 w-60 translate-x-1/4 rounded-full blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto max-w-7xl">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-topper text-accent m-0 uppercase">Our Services</p>
      <h2
        id="services-grid-title"
        class="text-section-title m-0 mt-3 text-balance text-neutral-950 uppercase"
      >
        Professional Electrical Services
      </h2>
      <p
        class="text-section-body text-copy-muted m-0 mx-auto mt-5 max-w-[46rem]"
      >
        From everyday repairs to full panel upgrades, every job is handled with
        clean workmanship, code-minded installs, and clear communication from
        start to finish.
      </p>
    </div>

    <ul
      class="m-0 mt-12 grid list-none gap-5 p-0 sm:gap-6 md:grid-cols-2 lg:mt-14 lg:grid-cols-3"
    >
      {
        serviceCards.map((card, index) => (
          <li
            class:list={[
              "h-full",
              index === 0 && "lg:col-span-2 lg:row-span-1",
            ]}
          >
            <a
              href={card.href}
              aria-label={`View service: ${card.title}`}
              class="group relative flex h-full flex-col overflow-hidden rounded-[1.75rem] border border-[rgba(0,40,79,0.08)] bg-[linear-gradient(145deg,rgba(255,255,255,1)_0%,rgba(249,243,232,0.86)_100%)] no-underline shadow-[0_18px_38px_rgba(0,40,79,0.06)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_28px_60px_rgba(0,40,79,0.14)]"
            >
              <div class="relative overflow-hidden">
                <Picture
                  class:list={[
                    "block w-full object-cover transition-transform duration-500 group-hover:scale-105",
                    index === 0 ? "h-72 lg:h-80" : "h-60",
                  ]}
                  src={card.cardImage}
                  alt={card.alt}
                />
                <div
                  class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,rgba(4,18,34,0)_55%,rgba(4,18,34,0.55)_100%)]"
                  aria-hidden="true"
                />
                <span
                  class="bg-accent text-primary absolute top-4 left-4 flex h-11 w-11 items-center justify-center rounded-full shadow-[0_10px_22px_rgba(0,40,79,0.22)]"
                  aria-hidden="true"
                >
                  <Icon name={card.icon} class="size-5" />
                </span>
              </div>

              <div class="flex flex-1 flex-col p-6 sm:p-7">
                <h3
                  class:list={[
                    "text-card-heading m-0 text-balance",
                    card.isAccent ? "text-accent" : "text-primary",
                  ]}
                >
                  {card.title}
                </h3>
                <p class="text-content-body m-0 mt-3 text-slate-600">
                  {card.shortDescription}
                </p>

                <div class="mt-6 flex items-center gap-2 text-[0.72rem] font-bold tracking-[0.16em] text-neutral-950 uppercase transition-colors duration-300 group-hover:text-accent">
                  <span>View Service</span>
                  <Icon
                    name="tabler:arrow-right"
                    class="size-4 shrink-0 transition-transform duration-300 group-hover:translate-x-1"
                    aria-hidden="true"
                  />
                </div>
              </div>
            </a>
          </li>
        ))
      }
    </ul>

    <div
      class="mt-12 flex flex-col items-center gap-4 sm:flex-row sm:flex-wrap sm:justify-center lg:mt-14"
    >
      <CtaPillButton
        href="/contact/"
        label="Get Free Quote"
        icon="tabler:file-invoice"
        ariaLabel="Get a free quote from Rod's Electrical"
        width="14rem"
      />
      <CtaPillButton
        href={`tel:${BUSINESS.phoneForTel}`}
        label={BUSINESS.phoneFormatted}
        icon="tabler:phone"
        ariaLabel={`Call ${BUSINESS.name} at ${BUSINESS.phoneFormatted}`}
        width="14rem"
        variant="light"
      />
    </div>
  </div>
</section>

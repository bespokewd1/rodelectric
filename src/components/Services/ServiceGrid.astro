---
import { Picture } from "astro:assets";
import { Icon } from "astro-icon/components";
import { serviceHubItems } from "@/data/services";

interface Props {
  ctaPrefix?: string;
  sectionId?: string;
}

const { ctaPrefix = "/services/#", sectionId = "services-grid" } =
  Astro.props as Props;

const gridAreas = ["streamline", "optimize", "build", "protect", "delegate"];
const accentTitleId = "panel-upgrades-inspections";

const serviceCards = serviceHubItems.map((service, index) => ({
  ...service,
  href: `${ctaPrefix}${service.id}`,
  gridArea: gridAreas[index] ?? `service-${index + 1}`,
  titleColor: service.id === accentTitleId ? "text-accent" : "",
}));
---

<section
  id={sectionId}
  class="py-section relative px-4"
  aria-labelledby="services-grid-title"
>
  <div
    class="mx-auto flex w-full max-w-7xl flex-col items-center gap-12 lg:flex-row lg:items-start lg:justify-between"
  >
    <!-- Left content -->
    <div
      class="flex w-full max-w-md flex-col items-center text-left lg:absolute lg:items-start xl:mt-50"
    >
      <span class="text-accent text-topper mb-6.25 block uppercase">
        Our Services
      </span>

      <!-- 3. Header with text gradient -->
      <!-- leading-[120%]  -->
      <h2
        id="services-grid-title"
        class="text-section-title m-0 mb-12 text-center tracking-normal text-neutral-950 md:text-nowrap lg:text-left"
      >
        Professional Electrical
        <br class="hidden md:inline" />
        Services
        <!-- the rest so you can focus
        <br class="hidden md:inline" />
        on what truly matters. -->
      </h2>

      <!-- <HireBtn /> -->
    </div>

    <!-- Right cards grid -->
    <ul
      id="use-case-grid"
      class="m-0 grid w-full max-w-xl p-0 lg:w-auto lg:max-w-none lg:flex-1"
    >
      {
        serviceCards.map((card) => (
          <li
            class="group flex list-none flex-col overflow-hidden rounded-2xl bg-gray-50/80 shadow-sm transition-shadow duration-300 hover:shadow-lg"
            data-card={card.gridArea}
            style={{ gridArea: card.gridArea }}
          >
            <a
              href={card.href ?? "#"}
              aria-label={`View service: ${card.title}`}
              class="block h-full no-underline"
            >
              <div class="overflow-hidden">
                <Picture
                  class="h-120 w-full object-cover transition-transform duration-300 group-hover:scale-110 lg:h-full lg:min-h-full lg:w-full"
                  src={card.cardImage}
                  alt={card.alt}
                />
              </div>
              <div class="p-6">
                <h3
                  class:list={[
                    "text-primary m-0 mb-3 text-xl font-bold",
                    card.titleColor ?? "",
                  ]}
                >
                  {card.title}
                </h3>
                <p class="m-0 text-base leading-relaxed text-slate-600">
                  {card.shortDescription}
                </p>
                <div class="group-hover:border-accent/30 group-hover:text-accent mt-5 inline-flex items-center gap-2 bg-white text-[0.72rem] font-bold tracking-[0.16em] text-neutral-950 uppercase transition-colors duration-300">
                  <span>View Service</span>
                  <Icon
                    name="tabler:arrow-right"
                    class="size-4 shrink-0 transition-transform duration-300 group-hover:translate-x-1"
                    aria-hidden="true"
                  />
                </div>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  @media (max-width: 1023px) {
    #use-case-grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        "streamline"
        "optimize"
        "build"
        "protect"
        "delegate";
      gap: 1.25rem;
    }
  }
  @media (min-width: 1024px) {
    #use-case-grid {
      display: grid;
      grid-template-columns: repeat(3, 19.06rem);
      grid-template-rows: auto 1fr 200px 1fr;
      grid-template-areas:
        "streamline optimize build"
        "streamline optimize build"
        "streamline optimize protect"
        "streamline delegate .";
      gap: 1.25rem;
      align-items: start;
      justify-content: end;
    }

    [data-card="streamline"] {
      place-self: center;
    }

    [data-card="optimize"] {
      align-self: end;
    }

    [data-card="build"] {
      align-self: end;
    }
    [data-card="build"] img {
      min-height: 321px;
    }

    [data-card="delegate"] {
    }

    [data-card="protect"] img {
      min-height: 396px;
    }
  }

  /* box-shadow: 0px 4px 100px 10px rgba(120, 43, 99, 0.39); */
</style>

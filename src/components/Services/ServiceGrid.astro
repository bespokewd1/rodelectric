---
import { Picture } from "astro:assets";
import { Icon } from "astro-icon/components";
import CtaPillButton from "@/components/CTA/CtaPillButton.astro";
import { serviceHubItems } from "@/data/services";
import { BUSINESS } from "@/data/client";

interface Props {
  ctaPrefix?: string;
  sectionId?: string;
}

const { ctaPrefix = "/services/#", sectionId = "services-grid" } =
  Astro.props as Props;

const sectionTitleId = `${sectionId}-title`;
const panelTitleId = `${sectionId}-panel-title`;
const serviceCount = serviceHubItems.length.toString().padStart(2, "0");

const serviceCards = serviceHubItems.map((service, index) => ({
  ...service,
  href: `${ctaPrefix}${service.id}`,
  number: `${index + 1}`.padStart(2, "0"),
  previewBullets: service.bullets.slice(0, 2),
}));

const cardInteractiveClasses =
  "hover:-translate-y-1 hover:border-[rgba(255,204,1,0.42)] hover:bg-[linear-gradient(140deg,rgba(255,204,1,0.12)_0%,rgba(255,255,255,0.06)_100%)] hover:shadow-[0_20px_40px_rgba(0,0,0,0.18)] focus-visible:-translate-y-1 focus-visible:border-[rgba(255,204,1,0.48)] focus-visible:bg-[linear-gradient(140deg,rgba(255,204,1,0.12)_0%,rgba(255,255,255,0.06)_100%)] focus-visible:shadow-[0_20px_40px_rgba(0,0,0,0.18)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--brand-accent)]/55 focus-visible:ring-offset-2 focus-visible:ring-offset-[var(--color-service-deep)]";
---

<section
  id={sectionId}
  class="py-section relative isolate overflow-hidden bg-[linear-gradient(180deg,rgba(255,255,255,1)_0%,rgba(237,244,248,0.45)_54%,rgba(255,248,239,0.8)_100%)] px-5 sm:px-6 lg:px-8"
  aria-labelledby={sectionTitleId}
>
  <div
    class="bg-accent/14 pointer-events-none absolute top-16 left-0 h-48 w-48 -translate-x-1/3 rounded-full blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div
    class="bg-primary/10 pointer-events-none absolute right-0 bottom-10 h-60 w-60 translate-x-1/4 rounded-full blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto max-w-7xl">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-topper text-accent m-0 uppercase">Our Services</p>
      <h2
        id={sectionTitleId}
        class="text-section-title m-0 mt-3 text-balance text-neutral-950 uppercase"
      >
        Professional Electrical Services
      </h2>
      <p
        class="text-section-body text-copy-muted m-0 mx-auto mt-5 max-w-[46rem]"
      >
        From everyday repairs to full panel upgrades, every job is handled with
        clean workmanship, code-minded installs, and clear communication from
        start to finish.
      </p>
    </div>

    <article
      aria-labelledby={panelTitleId}
      class="bg-service-deep mt-12 overflow-hidden rounded-[2.25rem] shadow-[0_30px_70px_rgba(0,17,34,0.28)] lg:mt-14"
    >
      <div
        class="grid gap-6 p-4 sm:p-6 xl:grid-cols-[minmax(0,0.78fr)_minmax(0,1.22fr)] xl:p-8"
      >
        <div
          class="flex flex-col rounded-[1.9rem] border border-white/10 bg-white/[0.05] p-6 text-white sm:p-8"
        >
          <p
            class="text-service-variant-label text-primary bg-accent m-0 inline-flex w-fit rounded-full px-4 py-2 uppercase"
          >
            Residential • Commercial • Upgrades
          </p>
          <h3
            id={panelTitleId}
            class="text-service-display m-0 mt-5 max-w-[13ch] text-white uppercase"
          >
            Electrical Support Built For Small Fixes And Bigger Projects
          </h3>
          <p class="m-0 mt-5 text-[1rem] leading-7 text-slate-300">
            From everyday repairs to full panel upgrades, every job is handled
            with clean workmanship, code-minded installs, and clear
            communication from start to finish.
          </p>

          <div class="mt-8 grid gap-3 sm:grid-cols-2">
            <div
              class="rounded-[1.35rem] border border-white/8 bg-white/[0.03] p-4"
            >
              <p class="text-service-variant-label m-0 text-white/70 uppercase">
                Core service paths
              </p>
              <p
                class="text-accent m-0 mt-2 text-[1.95rem] leading-none font-black"
              >
                {serviceCount}
              </p>
            </div>
            <div
              class="rounded-[1.35rem] border border-white/8 bg-white/[0.03] p-4"
            >
              <p class="text-service-variant-label m-0 text-white/70 uppercase">
                Work standard
              </p>
              <p
                class="m-0 mt-2 text-[0.98rem] leading-6 font-semibold text-white"
              >
                Clean, code-minded installs
              </p>
            </div>
          </div>

          <ul class="m-0 mt-6 grid list-none gap-3 p-0">
            <li
              class="flex items-start gap-3 rounded-[1.15rem] border border-white/8 bg-white/[0.03] px-4 py-3"
            >
              <span
                class="bg-accent/16 text-accent mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full"
                aria-hidden="true"
              >
                <Icon name="tabler:home-bolt" class="size-4" />
              </span>
              <span class="text-[0.95rem] leading-6 text-slate-200">
                Residential and commercial work handled with consistent
                workmanship.
              </span>
            </li>
            <li
              class="flex items-start gap-3 rounded-[1.15rem] border border-white/8 bg-white/[0.03] px-4 py-3"
            >
              <span
                class="bg-accent/16 text-accent mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full"
                aria-hidden="true"
              >
                <Icon name="tabler:bolt" class="size-4" />
              </span>
              <span class="text-[0.95rem] leading-6 text-slate-200">
                Troubleshooting, lighting, repairs, and panel upgrades from one
                service team.
              </span>
            </li>
            <li
              class="flex items-start gap-3 rounded-[1.15rem] border border-white/8 bg-white/[0.03] px-4 py-3"
            >
              <span
                class="bg-accent/16 text-accent mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full"
                aria-hidden="true"
              >
                <Icon name="tabler:message-circle-2" class="size-4" />
              </span>
              <span class="text-[0.95rem] leading-6 text-slate-200">
                Clear communication from first call through final walkthrough.
              </span>
            </li>
          </ul>

          <div
            class="mt-auto flex flex-col gap-4 pt-8 sm:flex-row sm:flex-wrap"
          >
            <CtaPillButton
              href="/contact/"
              label="Get Free Quote"
              icon="tabler:file-invoice"
              ariaLabel={`Get a free quote from ${BUSINESS.name}`}
              width="14rem"
              variant="light"
            />
            <CtaPillButton
              href={`tel:${BUSINESS.phoneForTel}`}
              label={BUSINESS.phoneFormatted}
              icon="tabler:phone"
              ariaLabel={`Call ${BUSINESS.name} at ${BUSINESS.phoneFormatted}`}
              width="14rem"
              variant="light"
            />
          </div>
        </div>

        <ul class="m-0 grid list-none gap-4 p-0">
          {
            serviceCards.map((card) => (
              <li>
                <a
                  href={card.href}
                  aria-label={`View service: ${card.title}`}
                  class={`group relative grid gap-4 overflow-hidden rounded-[1.65rem] border border-white/10 bg-white/[0.04] p-4 no-underline transition duration-300 sm:grid-cols-[9rem_minmax(0,1fr)] sm:items-center ${cardInteractiveClasses}`}
                >
                  <div class="relative min-h-32 overflow-hidden rounded-[1.35rem] sm:min-h-full">
                    <Picture
                      src={card.cardImage}
                      alt={card.alt}
                      class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105 group-focus-visible:scale-105"
                    />
                    <div
                      class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,rgba(4,18,34,0.08)_0%,rgba(4,18,34,0.5)_100%)]"
                      aria-hidden="true"
                    />
                    <span class="text-service-variant-label absolute top-3 left-3 rounded-full bg-black/35 px-3 py-2 text-white uppercase backdrop-blur-sm">
                      {card.number}
                    </span>
                  </div>

                  <div class="flex min-w-0 flex-col">
                    <div class="flex items-start justify-between gap-3">
                      <div class="min-w-0">
                        <p class="text-service-variant-label text-accent m-0 uppercase">
                          {card.shortNavLabel}
                        </p>
                        <h4 class="m-0 mt-2 text-[clamp(1.3rem,1vw+1.05rem,1.75rem)] leading-[1.08] font-bold text-white">
                          {card.title}
                        </h4>
                      </div>
                      <span
                        class="text-accent inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-white/[0.08]"
                        aria-hidden="true"
                      >
                        <Icon name={card.icon} class="size-5" />
                      </span>
                    </div>

                    <p class="m-0 mt-3 text-[0.98rem] leading-7 text-slate-300">
                      {card.detailHeading}
                    </p>

                    <ul class="m-0 mt-4 grid list-none gap-2 p-0">
                      {card.previewBullets.map((bullet) => (
                        <li class="flex items-start gap-2 text-[0.92rem] leading-6 text-slate-200">
                          <Icon
                            name="tabler:check"
                            class="text-accent mt-1 size-4 shrink-0"
                            aria-hidden="true"
                          />
                          <span>{bullet}</span>
                        </li>
                      ))}
                    </ul>

                    <div class="group-hover:text-accent group-focus-visible:text-accent mt-5 flex items-center gap-2 text-[0.72rem] font-bold tracking-[0.16em] text-white uppercase transition-colors duration-300">
                      <span>View Service</span>
                      <Icon
                        name="tabler:arrow-right"
                        class="size-4 shrink-0 transition-transform duration-300 group-hover:translate-x-1 group-focus-visible:translate-x-1"
                        aria-hidden="true"
                      />
                    </div>
                  </div>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </article>
  </div>
</section>

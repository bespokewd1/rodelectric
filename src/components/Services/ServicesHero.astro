---
import { Icon } from "astro-icon/components";
import type { GetImageResult } from "astro";

import CtaPillButton from "@/components/CTA/CtaPillButton.astro";
import { BUSINESS } from "@/data/client";

interface Props {
  image: GetImageResult;
}

const { image } = Astro.props as Props;

const supportItems = [
  {
    label: "Residential and commercial service",
    icon: "tabler:building",
  },
  {
    label: "Emergency troubleshooting available",
    icon: "tabler:bolt",
  },
  {
    label: "Clear quotes and code-compliant work",
    icon: "tabler:shield-check",
  },
];
---

<section
  id="services-hero"
  class="bg-bg-primary overflow-hidden pt-0"
  aria-labelledby="services-hero-title"
>
  <div class="mx-auto">
    <div
      class="grid gap-8 px-0 pt-10 pb-12 lg:grid-cols-2 lg:items-stretch lg:gap-0 lg:pt-0 lg:pb-0"
    >
      <div
        class="relative flex items-center px-[min(2rem,5vw)] lg:py-14 lg:pr-0 lg:pl-[min(20rem,5vw)] xl:py-18"
      >
        <div
          class="pointer-events-none absolute top-4 left-0 hidden h-36 w-36 rounded-full bg-[rgba(255,204,1,0.24)] blur-3xl lg:block"
          aria-hidden="true"
        >
        </div>
        <div
          class="pointer-events-none absolute right-8 bottom-0 hidden h-48 w-48 rounded-full bg-[rgba(255,255,255,0.75)] blur-3xl lg:block"
          aria-hidden="true"
        >
        </div>

        <div
          class="relative z-10 w-full rounded-4xl border border-white/70 bg-white/55 px-6 py-8 shadow-[0_24px_60px_rgba(111,84,42,0.10)] backdrop-blur-[2px] sm:px-8 sm:py-10 lg:rounded-none lg:border-0 lg:bg-transparent lg:px-0 lg:py-0 lg:shadow-none lg:backdrop-blur-none"
        >
          <p class="text-topper text-accent m-0 uppercase">All Services</p>

          <!-- class="text-primary mt-4 max-w-[13ch] text-[clamp(3rem,6.8vw,5.6rem)] leading-[0.93] font-black tracking-tighter text-balance" -->
          <h1
            id="services-hero-title"
            class="text-primary text-hero-title mt-4 max-w-[13ch] text-balance"
          >
            Electrical service
            <span class="text-accent">for homes, businesses,</span>
            and urgent calls across Edmonton.
          </h1>

          <p
            class="mt-6 max-w-2xl text-[1rem] leading-8 text-slate-600 sm:text-[1.08rem]"
          >
            Rod&apos;s Electrical handles residential electrical, commercial
            work, repairs, lighting installation, panel upgrades, inspections,
            and emergency support with clear communication and dependable
            scheduling.
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <CtaPillButton
              href="/contact/"
              label="Request Free Quote"
              icon="tabler:arrow-right"
              ariaLabel="Request a free quote from Rod's Electrical"
              width="14rem"
            />
            <CtaPillButton
              href={`tel:${BUSINESS.phoneForTel}`}
              label={BUSINESS.phoneFormatted}
              icon="tabler:phone"
              ariaLabel={`Call ${BUSINESS.name} at ${BUSINESS.phoneFormatted}`}
              width="14rem"
              variant="light"
            />
          </div>

          <ul class="mt-8 flex flex-wrap gap-3 p-0">
            {
              supportItems.map(({ label, icon }) => (
                <li class="min-w-0 flex-[1_1_16rem] rounded-full border border-white/80 bg-white/88 px-4 py-3 text-sm font-medium text-slate-700 shadow-[0_12px_26px_rgba(15,23,42,0.06)] backdrop-blur">
                  <span class="flex items-center gap-3">
                    <span
                      class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[rgba(255,204,1,0.18)] text-[var(--brand-strong)]"
                      aria-hidden="true"
                    >
                      <Icon name={icon} class="size-4" aria-hidden="true" />
                    </span>
                    <span class="min-w-0 text-balance">{label}</span>
                  </span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div
        class="relative px-[min(2rem,5vw)] lg:min-h-168 lg:px-0 xl:min-h-184"
      >
        <div
          class:list={[
            "relative min-h-72 overflow-hidden rounded-4xl shadow-[0_32px_80px_rgba(111,84,42,0.18)] ring-1 ring-black/5",
            "sm:min-h-96 md:min-h-120 lg:h-full lg:min-h-full lg:rounded-none lg:shadow-none lg:ring-0",
          ]}
        >
          <img
            src={image.src}
            alt="Rod's Electrical service hub for residential and commercial electrical work in Edmonton"
            width={image.attributes.width}
            height={image.attributes.height}
            class="absolute inset-0 h-full w-full object-cover object-[60%_24%] sm:object-[62%_20%] lg:object-[62%_center]"
            loading="eager"
            fetchpriority="high"
          />
          <div
            class="absolute inset-0 bg-[linear-gradient(180deg,rgba(249,243,232,0)_0%,rgba(249,243,232,0.1)_54%,rgba(249,243,232,0.42)_100%)] lg:bg-[linear-gradient(90deg,#f9f3e8_0%,rgba(249,243,232,0.94)_18%,rgba(249,243,232,0.56)_36%,rgba(249,243,232,0)_54%)]"
            aria-hidden="true"
          >
          </div>

          <div
            class="absolute right-4 bottom-4 left-4 sm:right-6 sm:bottom-6 sm:left-6 lg:hidden"
          >
            <div
              class="rounded-3xl border border-white/65 bg-white/90 p-5 shadow-[0_20px_50px_rgba(76,54,28,0.14)] backdrop-blur"
            >
              <p
                class="text-accent text-[0.72rem] font-bold tracking-[0.18em] uppercase"
              >
                Fast Response
              </p>
              <p class="mt-3 text-lg leading-7 font-semibold text-slate-900">
                Five core service areas, one dependable crew focused on safe,
                tidy, code-compliant results.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
